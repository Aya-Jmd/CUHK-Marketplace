<% content_for :title, "Notifications" %>

<div class="market-page market-page--soft notification-page">
  <section class="market-page__hero">
    <div class="market-page__hero-inner market-page__hero-inner--wide">
      <h1 class="market-page__title">Notifications</h1>
    </div>
  </section>

  <div class="market-page__body">
    <section class="market-surface-card notification-page__controls">
      <section class="items-category-strip notification-page__tabs-strip" aria-label="Notification categories">
        <div class="notification-page__tabs-row">
          <div>
          <% notification_categories.each do |category, label| %>
            <%= link_to notifications_path(notification_filter_params(category: category, show_unread_only: @show_unread_only)),
                class: class_names("items-category-strip__item notification-page__tab", { "is-active" => @selected_category == category }) do %>
              <span><%= label %></span>
              <span class="notification-page__tab-count"><%= @category_counts[category] || 0 %></span>
            <% end %>
          <% end %>
          </div>

          <div class="notification-page__toolbar">
            <%= form_with url: notifications_path, method: :get, local: true, class: "notification-page__toggle-form" do %>
              <%= hidden_field_tag :category, @selected_category %>
              <%= hidden_field_tag :show_unread, "0" %>
              <label class="notification-page__toggle">
                <%= check_box_tag :show_unread, "1", @show_unread_only, id: "notifications_show_unread", onchange: "this.form.requestSubmit()" %>
                <span>Show only unread</span>
              </label>
            <% end %>

            <% if @has_unread_notifications %>
              <%= button_to "Mark all as read",
                  mark_all_as_read_notifications_path(notification_filter_params(category: @selected_category, show_unread_only: @show_unread_only)),
                  method: :patch,
                  class: "market-button market-button--secondary market-button--compact notification-page__mark-all" %>
            <% end %>
          </div>
        </div>
      </section>
    </section>

    <section class="market-surface-card notification-page__list">
      <% if @notifications.any? %>
        <div class="notification-page__stack" data-controller="scroll-reset">
          <% @notifications.each do |notification| %>
            <%= render "notification", notification: notification %>
          <% end %>
        </div>
      <% else %>
        <div class="market-empty-state">
          <p>No notifications match the selected category.</p>
        </div>
      <% end %>
    </section>
  </div>
</div>
