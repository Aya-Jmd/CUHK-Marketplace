<% unread = notification.read_at.nil? %>
<% short_timestamp = notification.created_at.strftime("%b %d, %H:%M") %>

<% if actionable_report_notification?(notification) %>
  <article class="notification-card notification-card--actionable <%= "notification-card--unread" if unread %>">
    <div class="notification-card__content notification-card__content--actionable">
      <div class="notification-card__header">
        <div class="notification-card__message">
          <%= notification_report_message(notification) %>
        </div>
        <span class="notification-card__badge notification-card__badge--pending">Pending</span>
      </div>

      <% if notification_detail_message(notification).present? %>
        <p class="notification-card__detail"><%= notification_detail_message(notification) %></p>
      <% end %>

      <div class="notification-card__footer">
        <p class="notification-card__timestamp"><%= short_timestamp %></p>

        <div class="notification-card__rail">
          <%= link_to "View listing",
              notification_mark_as_read_path(notification),
              data: { turbo_method: :patch },
              class: "market-button market-button--secondary market-button--compact" %>
          <%= button_to "Delete item", delete_item_admin_item_report_path(notification.notifiable), method: :patch,
              data: { turbo_confirm: "Remove this item from the marketplace?" },
              class: "market-button market-button--danger market-button--compact" %>
          <%= button_to "Ignore report", ignore_admin_item_report_path(notification.notifiable), method: :patch,
              class: "market-button market-button--secondary market-button--compact" %>
        </div>
      </div>
    </div>
  </article>
<% elsif offer_notification?(notification) %>
  <article class="notification-card notification-card--offer <%= "notification-card--unread" if unread %>">
    <%= link_to notification_offer_card_path(notification),
        data: { turbo_method: :patch },
        class: "notification-card__overlay-link",
        aria: { label: "Open this offer notification in your dashboard" } do %>
      <span class="notification-card__overlay-label">Open in dashboard</span>
    <% end %>

    <div class="notification-card__header">
      <div class="notification-card__message"><%= notification_offer_message(notification) %></div>
      <% if notification_offer_badge_label(notification).present? %>
        <span class="notification-card__badge <%= notification_offer_badge_class(notification) %>">
          <%= notification_offer_badge_label(notification) %>
        </span>
      <% end %>
    </div>

    <% if notification_offer_detail_message(notification).present? %>
      <p class="notification-card__detail"><%= notification_offer_detail_message(notification) %></p>
    <% end %>

    <p class="notification-card__timestamp"><%= short_timestamp %></p>
  </article>
<% else %>
  <article class="notification-card notification-card--standard <%= "notification-card--unread" if unread %>">
    <div class="notification-card__header">
      <div class="notification-card__message">
        <%= notification_standard_message(notification) %>
      </div>
      <% if notification_badge_label(notification).present? %>
        <span class="notification-card__badge notification-card__badge--resolved"><%= notification_badge_label(notification) %></span>
      <% end %>
    </div>

    <% if notification_detail_message(notification).present? %>
      <p class="notification-card__detail"><%= notification_detail_message(notification) %></p>
    <% end %>

    <p class="notification-card__timestamp"><%= short_timestamp %></p>
  </article>
<% end %>
