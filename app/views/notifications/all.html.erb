<div style="max-width: 960px; margin: 0 auto; padding: 24px;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <h1 style="margin: 0;">NOTIFICATIONS</h1>

    <% if @notifications.any? { |notification| notification.read_at.nil? } %>
      <%= button_to "Mark all as read", mark_all_as_read_notifications_path, method: :patch,
          style: "padding: 8px 12px; border: 1px solid #ccc; background: white; cursor: pointer;" %>
    <% end %>
  </div>

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;" >
        <%= button_to "All", all_notifications_path, method: :get%>
        <%= button_to "Unread", notifications_path, method: :get %>
    </div>

  <% if @notifications.any? %>
    <div>
      <% @notifications.each do |notification| %>
        <% unread = notification.read_at.nil? %>
          <%= link_to mark_as_read_notification_path(notification),
              data: { turbo_method: :patch },
              style: "display: block; text-decoration: none; color: inherit; border: 1px solid #ddd; 
              padding: 14px 16px; margin-bottom: 10px; background: #{unread ? '#f8fbff' : 'white'};" do %>
          <div style="font-weight: 600; margin-bottom: 6px;"><%= notification_message(notification) %></div>
          <div style="font-size: 0.9em; color: #666;"><%= notification.created_at.strftime("%B %d, %Y at %I:%M %p") %></div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p>No new notifications yet.</p>
  <% end %>
</div>
