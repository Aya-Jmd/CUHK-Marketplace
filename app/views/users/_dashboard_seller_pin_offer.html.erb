<% form_id = "complete-offer-#{offer.id}" %>

<article class="profile-item-row profile-item-row--flat profile-item-row--pin-card profile-item-row--seller-accepted profile-item-row--dashboard-linkable profile-seller-pin-offer" role="listitem">
  <div class="profile-seller-pin-offer__header">
    <div class="profile-seller-pin-offer__identity">
      <div class="profile-item-row__title-line">
        <h3 class="profile-item-row__title"><%= item.title %></h3>
        <span class="profile-item-row__counterparty">, <%= offer.buyer.display_name %></span>
        <span class="profile-item-row__counterparty">, <%= offer.created_at.strftime("%b %d, %Y") %></span>
      </div>
    </div>

    <div class="profile-seller-pin-offer__price profile-item-row__price-meta">
      <div class="profile-item-row__summary profile-item-row__summary--tooltip">
        <button type="button" class="profile-item-row__info-trigger" aria-label="Show sale help">
          ?
          <span class="profile-item-row__info-popover" role="tooltip">Ask the buyer for their meetup PIN to complete the sale.</span>
        </button>
      </div>

      <div class="profile-item-row__price-block profile-item-row__price-block--dashboard profile-item-row__price-block--pin-card">
        <strong class="profile-item-row__price-value"><%= display_price(offer.price) %></strong>
      </div>
    </div>
  </div>

  <div class="profile-seller-pin-offer__controls">
    <%= form_with url: complete_offer_path(offer), method: :patch, id: form_id, class: "profile-seller-pin-offer__form", data: { controller: "pin-input", action: "submit->pin-input#handleSubmit" } do %>
      <div class="profile-seller-pin-offer__pin-group">
        <p class="profile-item-row__summary-line profile-item-row__summary-line--label">Meetup PIN</p>
        <%= hidden_field_tag :meetup_code, nil, data: { pin_input_target: "hidden" } %>
        <div class="profile-pin-code profile-pin-code--entry" role="group" aria-label="Enter the 4-digit meetup PIN">
          <% 4.times do |digit_index| %>
            <input
              type="text"
              maxlength="1"
              inputmode="numeric"
              pattern="[0-9]*"
              autocomplete="<%= digit_index.zero? ? "one-time-code" : "off" %>"
              aria-label="Meetup PIN digit <%= digit_index + 1 %>"
              class="profile-pin-code__digit profile-pin-code__digit--input"
              data-pin-input-target="digit"
              data-action="input->pin-input#handleInput keydown->pin-input#handleKeydown paste->pin-input#handlePaste focus->pin-input#handleFocus"
              required
            >
          <% end %>
        </div>
      </div>
    <% end %>

    <%= button_tag "Complete sale",
        type: "submit",
        form: form_id,
        class: "market-button market-button--compact profile-seller-pin-offer__submit",
        aria: { label: "Complete sale for #{item.title}" } %>

    <div class="profile-item-row__action-bar profile-seller-pin-offer__cancel">
      <%= button_to "Cancel transaction", cancel_offer_path(offer), method: :patch, data: { turbo_confirm: "Are you sure? This will put the item back on the market." }, class: "market-button market-button--danger market-button--compact", form: { class: "profile-pin-inline-form" } %>
    </div>
  </div>

  <%= link_to item_path(item), class: "profile-item-row__dashboard-overlay-link", aria: { label: "View #{item.title}" } do %>
    <span class="item-show__screen-reader">View <%= item.title %></span>
  <% end %>
</article>
