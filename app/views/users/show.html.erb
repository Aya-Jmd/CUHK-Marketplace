<div style="max-width: 1200px; margin: 0 auto; padding: 20px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; padding-bottom: 100px;">

  <div style="margin-bottom: 40px; display: flex; justify-content: space-between; align-items: flex-start;">
    <div>
      <h1 style="font-size: 2.5em; color: #2c3e50; margin-bottom: 10px;">
        <%= current_user == @user ? "My Dashboard" : "#{@user.email}'s Profile" %>
      </h1>
      <p style="color: #7f8c8d; font-size: 1.1em; margin: 0;">🎓 College: <strong><%= @user.college&.name || "Not specified" %></strong></p>
    </div>
    <%= link_to "⬅️ Back to Home", root_path, style: "background-color: #f8f9fa; color: #2c3e50; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: bold; border: 1px solid #dcdde1;" %>
  </div>

  <% if current_user == @user %>
    <div style="display: flex; flex-wrap: wrap; gap: 30px;">
      
      <div style="flex: 1; min-width: 300px; background: white; border-radius: 16px; padding: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.03); border-top: 5px solid #6c5ce7;">
        <h2 style="margin-top: 0; color: #2d3436; display: flex; align-items: center; justify-content: space-between;">
          <span>📦 Seller Hub</span>
          <%= link_to "+ Post Item", new_item_path, style: "font-size: 0.6em; background: #6c5ce7; color: white; padding: 8px 15px; border-radius: 6px; text-decoration: none;" %>
        </h2>
        <hr style="border: 0; border-top: 1px solid #f1f2f6; margin-bottom: 20px;">

        <% active_items = @user.items.where(status: ['available', 'pending_dropoff']).order(created_at: :desc) %>
        <% if active_items.any? %>
          <% active_items.each do |item| %>
            <div style="padding: 15px; border: 1px solid #e1e8ed; border-radius: 10px; margin-bottom: 15px; background-color: #fafbff;">
              <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                <%= link_to item.title, item_path(item), style: "font-weight: bold; color: #2d3436; text-decoration: none; font-size: 1.1em;" %>
                <span style="color: <%= item.status == 'available' ? '#27ae60' : '#f39c12' %>; font-weight: bold; font-size: 0.9em;"><%= item.status.upcase %></span>
              </div>

              <% item.offers.where(status: ['pending', 'accepted']).each do |offer| %>
                <div style="margin-top: 10px; padding: 12px; background: <%= offer.accepted? ? '#fff9db' : 'white' %>; border: 1px solid #ddd; border-radius: 8px;">
                  <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                    <span>Offer: <strong><%= display_price(offer.price) %></strong></span>
                    <span style="color: #7f8c8d; font-size: 0.9em;"><%= offer.buyer.email.split('@').first %></span>
                  </div>

                  <% if offer.pending? %>
                    <div style="display: flex; gap: 10px;">
                      <%= button_to "Accept", accept_offer_path(offer), method: :patch, style: "background: #27ae60; color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; flex: 1;" %>
                      <%= button_to "Decline", decline_offer_path(offer), method: :patch, style: "background: #e74c3c; color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer;" %>
                    </div>
                  <% elsif offer.accepted? %>
                    <div style="border-top: 1px dashed #f39c12; padding-top: 10px; margin-top: 5px;">
                      <p style="font-size: 0.85em; color: #e67e22; margin: 0 0 8px 0;"><strong>Reserved.</strong> Ask the buyer for their PIN:</p>
                      <%= form_with url: complete_offer_path(offer), method: :patch, data: { controller: "pin-input" }, style: "margin-bottom: 15px;" do |f| %>
                        
                        <div style="display: flex; justify-content: space-between; gap: 8px; margin-bottom: 12px;">
                          <% 4.times do %>
                            <input type="text" 
                                  maxlength="1" 
                                  inputmode="numeric" 
                                  pattern="[0-9]*"
                                  autocomplete="one-time-code"
                                  data-pin-input-target="digit"
                                  data-action="input->pin-input#handleInput keydown->pin-input#handleKeydown paste->pin-input#handlePaste"
                                  style="width: 50px; height: 60px; font-size: 1.8em; text-align: center; border: 2px solid #cbd5e1; border-radius: 8px; font-weight: bold; color: #2c3e50; outline-color: #00cec9; flex: 1;">
                          <% end %>
                        </div>

                        <%= f.hidden_field :meetup_code, data: { pin_input_target: "hidden" }, required: true %>

                        <%= f.submit "Complete Sale", style: "width: 100%; background: #0984e3; color: white; border: none; padding: 12px; border-radius: 8px; font-size: 1em; font-weight: bold; cursor: pointer; transition: background 0.2s;" %>

                      <% end %>
                      <%= button_to "Buyer didn't show? Cancel Transaction", cancel_offer_path(offer), method: :patch, data: { turbo_confirm: "Are you sure? This will put the item back on the market." }, style: "background: none; border: none; color: #e74c3c; text-decoration: underline; font-size: 0.8em; cursor: pointer; padding: 0;" %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <p style="color: #a4b0be; font-style: italic;">No active listings or offers.</p>
        <% end %>
      </div>

      <div style="flex: 1; min-width: 300px; background: white; border-radius: 16px; padding: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.03); border-top: 5px solid #00cec9;">
        <h2 style="margin-top: 0; color: #2d3436;"><span>🛍️ Buyer Hub</span></h2>
        <hr style="border: 0; border-top: 1px solid #f1f2f6; margin-bottom: 20px;">

        <% active_bids = @user.offers_made.where(status: ['pending', 'accepted']).order(created_at: :desc) %>
        <% if active_bids.any? %>
          <% active_bids.each do |offer| %>
            <div style="padding: 15px; border: 1px solid #e1e8ed; border-radius: 10px; margin-bottom: 12px; border-left: 5px solid <%= offer.accepted? ? '#27ae60' : '#fab005' %>;">
              <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                <%= link_to offer.item.title, item_path(offer.item), style: "font-weight: bold; color: #2d3436; text-decoration: none;" %>
                <span style="font-weight: bold; color: <%= offer.accepted? ? '#27ae60' : '#f39c12' %>"><%= offer.status.upcase %></span>
              </div>
              <div style="color: #7f8c8d; font-size: 0.9em;">My Bid: <strong><%= display_price(offer.price) %></strong></div>

              <% if offer.accepted? %>
                <div style="margin-top: 12px; padding: 15px; background: #e8f8f5; border-radius: 8px; text-align: center;">
                  <span style="display: block; font-size: 0.8em; color: #16a085; font-weight: bold;">MEETUP PIN</span>
                  <span style="font-size: 2em; font-weight: 900; letter-spacing: 5px; color: #2c3e50;"><%= offer.meetup_code %></span>
                  <p style="font-size: 0.8em; color: #16a085; margin: 5px 0 0 0;">Show this to the seller to receive your item.</p>
                </div>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <p style="color: #a4b0be; font-style: italic;">You have no active bids.</p>
        <% end %>
      </div>
    </div>
  <% else %>
    <div style="background: white; border-radius: 16px; padding: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.03);">
      <h2 style="margin-top: 0;">Items posted by <%= @user.email.split('@').first %></h2>
      <ul style="list-style: none; padding: 0;">
        <% public_items = @user.items.where(status: 'available').order(created_at: :desc) %>
        <% if public_items.any? %>
          <% public_items.each do |item| %>
            <li style="padding: 15px; border: 1px solid #e1e8ed; border-radius: 10px; margin-bottom: 10px;">
              <%= link_to item.title, item_path(item), style: "font-weight: bold; color: #0984e3; text-decoration: none;" %>
              <span style="float: right; font-weight: bold;"><%= display_price(item.price) %></span>
            </li>
          <% end %>
        <% else %>
          <p style="color: #a4b0be;">No available items right now.</p>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
