<% profile_owner = current_user == @user %>
<% display_name = @user.display_name %>
<% active_items = @user.items.where(status: ["available", "pending_dropoff"]).includes(offers: :buyer).order(created_at: :desc) %>
<% pending_bids = profile_owner ? @user.offers_made.where(status: "pending").includes(:item).order(created_at: :desc) : Offer.none %>
<% accepted_bids = profile_owner ? @user.offers_made.where(status: "accepted").includes(:item).order(created_at: :desc) : Offer.none %>
<% public_items = @user.banned? ? Item.none : @user.items.where(status: "available").order(created_at: :desc) %>
<% seller_offer_rows = if profile_owner
    active_items.flat_map do |item|
      item.offers
        .select { |offer| offer.pending? || offer.accepted? }
        .sort_by { |offer| [offer.pending? ? 0 : 1, -offer.updated_at.to_i] }
        .map { |offer| [item, offer] }
    end
  else
    []
  end %>
<% seller_items_without_active_offers = if profile_owner
    active_items.select { |item| item.offers.none? { |offer| offer.pending? || offer.accepted? } }
  else
    []
  end %>
<% content_for :title, profile_owner ? "My Items" : "#{display_name}'s profile" %>
<div class="<%= class_names("market-page market-page--item profile-show-page", { "profile-show-page--dashboard" => profile_owner }) %>">
  <% if profile_owner %>
    <section class="market-page__hero profile-dashboard__hero">
      <div class="market-page__hero-inner profile-dashboard__hero-inner">
        <h1 class="market-page__title">Dashboard</h1>
      </div>
    </section>
  <% else %>
    <section class="item-show__hero profile-show__hero">
      <div class="item-show__shell">
        <div class="profile-show__hero-card">
          <div class="profile-show__hero-copy">
            <h1 class="market-page__title"><%= "#{display_name}'s profile" %></h1>

            <div class="item-show__hero-tags profile-show__hero-tags">
              <span class="item-show__hero-tag"><%= @user.college&.name || "College not specified" %></span>
              <span class="item-show__hero-tag"><%= pluralize(public_items.size, "seller item") %></span>
            </div>

            <p class="market-page__lede">
              Browse the items this seller currently has available on the CUHK marketplace.
            </p>

            <div class="market-page__actions">
              <%= link_to "Back to marketplace", items_path(marketplace_base_params), class: "market-button market-button--light" %>
            </div>
          </div>

          <aside class="profile-show__hero-panel">
            <div class="profile-show__hero-avatar" aria-hidden="true"><%= @user.display_name.first.to_s.upcase %></div>
            <div class="profile-show__hero-panel-copy">
              <h2 class="profile-show__hero-panel-title"><%= @user.display_name %></h2>
            </div>
          </aside>
        </div>
      </div>
    </section>
  <% end %>

  <div class="item-show__shell profile-show__content">
    <div class="<%= class_names("profile-show__sections", { "profile-show__sections--dashboard" => profile_owner }) %>">
      <% if profile_owner %>
        <%= render "users/favorite_items_section", favorite_items: @favorite_items %>
      <% end %>

      <section class="market-surface-card profile-show__section">
        <div class="market-section-heading profile-show__section-heading">
          <div>
            <p class="market-section-eyebrow"><%= profile_owner ? "Selling" : "Seller inventory" %></p>
            <h2 class="market-section-title"><%= profile_owner ? "Listings and incoming offers" : "Available listings" %></h2>
            <p class="market-note">
              <%= profile_owner ? "Follow each listing from first offer to final completion, all in one place." : "Only items that are currently visible on the marketplace are shown here." %>
            </p>
          </div>

          <% if profile_owner %>
            <%= link_to "Add new item", new_item_path, class: "market-button market-button--light" %>
          <% end %>
        </div>

        <% if profile_owner ? (seller_offer_rows.any? || seller_items_without_active_offers.any?) : public_items.any? %>
          <div class="profile-show__rows <%= "profile-show__rows--dashboard-flat" if profile_owner %>" role="list">
            <% if profile_owner %>
              <% seller_offer_rows.each do |item, offer| %>
                <article class="<%= class_names("profile-item-row profile-item-row--flat profile-item-row--dashboard-linkable", { "profile-item-row--pin-card profile-item-row--seller-accepted" => offer.accepted? }) %>" role="listitem">
                  <% if offer.pending? %>
                    <div class="profile-item-row__top">
                      <div class="profile-item-row__identity">
                        <p class="profile-item-row__meta">
                          <span>Incoming offer</span>
                          <span><%= item.category&.name || "Uncategorized" %></span>
                          <span><%= offer.created_at.strftime("%b %d, %Y") %></span>
                        </p>

                        <h3 class="profile-item-row__title"><%= item.title %></h3>

                        <div class="profile-item-row__badges">
                          <span class="profile-status-badge profile-status-badge--pending">PENDING</span>
                          <span class="profile-status-badge profile-status-badge--neutral"><%= item.college&.name || "CUHK" %></span>
                        </div>
                      </div>

                      <div class="profile-item-row__price-block">
                        <p class="profile-item-row__price-label">Price</p>
                        <strong class="profile-item-row__price-value"><%= display_price(offer.price) %></strong>
                      </div>
                    </div>

                    <div class="profile-item-row__footer">
                      <div class="profile-item-row__summary">
                        <p class="profile-item-row__summary-line">
                          <strong><%= offer.buyer.display_name %></strong>
                          sent an offer for this listing.
                        </p>
                      </div>

                      <div class="profile-item-row__action-bar">
                        <%= button_to "Accept", accept_offer_path(offer), method: :patch, class: "market-button market-button--compact", form: { class: "profile-action-form" } %>
                        <%= button_to "Refuse", decline_offer_path(offer), method: :patch, class: "market-button market-button--secondary market-button--compact", form: { class: "profile-action-form" } %>
                      </div>
                    </div>
                  <% else %>
                    <div class="profile-item-row__top profile-item-row__top--pin-card">
                      <div class="profile-item-row__pin-panel">
                        <div class="profile-item-row__pin-header">
                          <p class="profile-item-row__meta profile-item-row__meta--pin-panel">
                            <span>Accepted offer</span>
                            <span><%= item.category&.name || "Uncategorized" %></span>
                            <span><%= offer.created_at.strftime("%b %d, %Y") %></span>
                          </p>
                          <h3 class="profile-item-row__title profile-item-row__title--pin-panel"><%= item.title %></h3>
                        </div>

                        <%= form_with url: complete_offer_path(offer), method: :patch, id: "complete-offer-#{offer.id}", class: "profile-pin-entry-form", data: { controller: "pin-input", action: "submit->pin-input#handleSubmit" } do %>
                          <div class="profile-pin-entry-form__group">
                            <p class="profile-item-row__summary-line profile-item-row__summary-line--label">Meetup PIN</p>
                            <%= hidden_field_tag :meetup_code, nil, data: { pin_input_target: "hidden" } %>
                            <div class="profile-pin-code profile-pin-code--entry" role="group" aria-label="Enter the 4-digit meetup PIN">
                              <% 4.times do |digit_index| %>
                                <input
                                  type="text"
                                  maxlength="1"
                                  inputmode="numeric"
                                  pattern="[0-9]*"
                                  autocomplete="<%= digit_index.zero? ? "one-time-code" : "off" %>"
                                  aria-label="Meetup PIN digit <%= digit_index + 1 %>"
                                  class="profile-pin-code__digit profile-pin-code__digit--input"
                                  data-pin-input-target="digit"
                                  data-action="input->pin-input#handleInput keydown->pin-input#handleKeydown paste->pin-input#handlePaste focus->pin-input#handleFocus"
                                  required
                                >
                              <% end %>
                            </div>
                          </div>
                          <%= button_tag "submit", type: "submit", class: "market-button market-button--compact profile-pin-entry-form__submit" %>
                        <% end %>
                      </div>

                      <div class="profile-item-row__identity profile-item-row__identity--pin-card">
                        <div class="profile-item-row__price-meta">
                          <div class="profile-item-row__summary profile-item-row__summary--tooltip">
                            <button type="button" class="profile-item-row__info-trigger" aria-label="Show sale help">
                              ?
                              <span class="profile-item-row__info-popover" role="tooltip">Ask the buyer for their meetup PIN to complete the sale.</span>
                            </button>
                          </div>

                          <div class="profile-item-row__price-block">
                            <p class="profile-item-row__price-label">Price</p>
                            <strong class="profile-item-row__price-value"><%= display_price(offer.price) %></strong>
                          </div>
                        </div>

                        <p class="profile-item-row__summary-line profile-item-row__summary-line--headline">
                          With <span class="profile-item-row__inline-emphasis"><%= offer.buyer.display_name %></span>
                        </p>
                        <div class="profile-item-row__action-bar profile-item-row__action-bar--pin-side">
                          <%= button_to "Cancel transaction", cancel_offer_path(offer), method: :patch, data: { turbo_confirm: "Are you sure? This will put the item back on the market." }, class: "market-button market-button--danger market-button--compact", form: { class: "profile-action-form" } %>
                        </div>
                      </div>
                    </div>

                    <div class="profile-item-row__footer profile-item-row__footer--pin-card">
                      <div class="profile-item-row__summary profile-item-row__summary--tooltip profile-item-row__summary--pin-help">
                      </div>

                      <div class="profile-item-row__action-bar profile-item-row__action-bar--pin-footer">
                        <%= button_tag "✔", type: "submit", form: "complete-offer-#{offer.id}", class: "market-button market-button--compact" %>
                        <%= button_to "Cancel transaction", cancel_offer_path(offer), method: :patch, data: { turbo_confirm: "Are you sure? This will put the item back on the market." }, class: "market-button market-button--danger market-button--compact", form: { class: "profile-action-form" } %>
                      </div>
                    </div>
                  <% end %>
                  <%= link_to item_path(item), class: "profile-item-row__dashboard-overlay-link", aria: { label: "View #{item.title}" } do %>
                    <span class="item-show__screen-reader">View <%= item.title %></span>
                  <% end %>
                </article>
              <% end %>

              <% seller_items_without_active_offers.each do |item| %>
                <article class="profile-item-row profile-item-row--flat profile-item-row--inventory-card profile-item-row--dashboard-linkable" role="listitem">
                  <div class="profile-item-row__top">
                    <div class="profile-item-row__identity">
                      <p class="profile-item-row__meta">
                        <span><%= item.category&.name || "Uncategorized" %></span>
                        <span><%= item.created_at.strftime("%b %d, %Y") %></span>
                      </p>

                      <h3 class="profile-item-row__title"><%= item.title %></h3>

                      <div class="profile-item-row__badges">
                        <span class="profile-status-badge <%= item.status == "available" ? "profile-status-badge--live" : "profile-status-badge--reserved" %>">
                          <%= item.status == "available" ? "LIVE" : item.status.upcase %>
                        </span>
                        <span class="profile-status-badge profile-status-badge--neutral"><%= item.college&.name || "CUHK" %></span>
                      </div>
                    </div>

                    <div class="profile-item-row__price-block">
                      <p class="profile-item-row__price-label">Price</p>
                      <strong class="profile-item-row__price-value"><%= display_price(item.price) %></strong>
                    </div>
                  </div>

                  <div class="profile-item-row__footer profile-item-row__footer--inventory-card">
                    <% if item.status == "available" %>
                      <div class="profile-item-row__action-bar profile-item-row__action-bar--inventory">
                        <%= button_to "Remove item", item_path(item, return_to: "dashboard"), method: :delete, data: { turbo_confirm: "Remove this live item from the marketplace?" }, class: "market-button market-button--danger market-button--compact", form: { class: "profile-action-form" } %>
                      </div>
                    <% end %>
                  </div>
                  <%= link_to item_path(item), class: "profile-item-row__dashboard-overlay-link", aria: { label: "View #{item.title}" } do %>
                    <span class="item-show__screen-reader">View <%= item.title %></span>
                  <% end %>
                </article>
              <% end %>
            <% else %>
              <% public_items.each do |item| %>
                <article class="profile-item-row profile-item-row--linkable" role="listitem">
                  <%= link_to item_path(item), class: "profile-item-row__card-link" do %>
                    <div class="profile-item-row__top">
                      <div class="profile-item-row__identity">
                        <p class="profile-item-row__meta">
                          <span><%= item.category&.name || "Uncategorized" %></span>
                          <span><%= item.created_at.strftime("%b %d, %Y") %></span>
                        </p>

                        <h3 class="profile-item-row__title"><%= item.title %></h3>

                        <div class="profile-item-row__badges">
                          <span class="profile-status-badge <%= item.status == "available" ? "profile-status-badge--live" : "profile-status-badge--reserved" %>">
                            <%= item.status == "available" ? "LIVE" : item.status.upcase %>
                          </span>
                          <span class="profile-status-badge profile-status-badge--neutral"><%= item.college&.name || "CUHK" %></span>
                        </div>
                      </div>

                      <div class="profile-item-row__price-block">
                        <p class="profile-item-row__price-label">Price</p>
                        <strong class="profile-item-row__price-value"><%= display_price(item.price) %></strong>
                      </div>
                    </div>
                  <% end %>
                </article>
              <% end %>
            <% end %>
          </div>
        <% elsif !profile_owner && @user.banned? %>
          <div class="market-empty-state">
            <p>This seller is currently banned.</p>
          </div>
        <% else %>
          <div class="market-empty-state">
            <p><%= profile_owner ? "You have no active listings right now." : "No available items right now." %></p>
          </div>
        <% end %>
      </section>

      <% if profile_owner %>
        <section class="market-surface-card profile-show__section">
          <div class="market-section-heading profile-show__section-heading">
            <div>
              <p class="market-section-eyebrow">Buying</p>
              <h2 class="market-section-title">Offers you are tracking</h2>
              <p class="market-note">
                Keep an eye on the offers you have placed and the listings that are already confirmed.
              </p>
            </div>

            <%= link_to "Browse items", items_path(marketplace_base_params), class: "market-button market-button--light" %>
          </div>

          <% if pending_bids.any? || accepted_bids.any? %>
            <div class="profile-show__rows profile-show__rows--dashboard-flat" role="list">
              <% pending_bids.each do |offer| %>
                <article class="profile-item-row profile-item-row--flat profile-item-row--dashboard-linkable" role="listitem">
                  <div class="profile-item-row__top">
                    <div class="profile-item-row__identity">
                      <p class="profile-item-row__meta">
                        <span>Pending offer</span>
                        <span><%= offer.item.category&.name || "Uncategorized" %></span>
                        <span><%= offer.created_at.strftime("%b %d, %Y") %></span>
                      </p>
                      <h3 class="profile-item-row__title"><%= offer.item.title %></h3>
                      <div class="profile-item-row__badges">
                        <span class="profile-status-badge profile-status-badge--pending">PENDING</span>
                        <span class="profile-status-badge profile-status-badge--neutral"><%= offer.item.college&.name || "CUHK" %></span>
                      </div>
                    </div>

                    <div class="profile-item-row__price-meta">
                      <div class="profile-item-row__summary profile-item-row__summary--tooltip">
                        <button type="button" class="profile-item-row__info-trigger" aria-label="Show offer status help">
                          ?
                          <span class="profile-item-row__info-popover" role="tooltip">The seller has not responded yet. You can still cancel this offer.</span>
                        </button>
                      </div>

                      <div class="profile-item-row__price-block">
                        <p class="profile-item-row__price-label">Price</p>
                        <strong class="profile-item-row__price-value"><%= display_price(offer.price) %></strong>
                      </div>
                    </div>
                  </div>

                  <div class="profile-item-row__footer profile-item-row__footer--tracking-card">
                    <div class="profile-item-row__summary profile-item-row__summary--pin-help"></div>
                    <div class="profile-item-row__action-bar profile-item-row__action-bar--tracking">
                      <%= button_to "Cancel offer", offer_path(offer), method: :delete, data: { turbo_confirm: "Cancel this bid?" }, class: "market-button market-button--danger market-button--compact", form: { class: "profile-action-form" } %>
                    </div>
                  </div>
                  <%= link_to item_path(offer.item), class: "profile-item-row__dashboard-overlay-link", aria: { label: "View #{offer.item.title}" } do %>
                    <span class="item-show__screen-reader">View <%= offer.item.title %></span>
                  <% end %>
                </article>
              <% end %>

              <% accepted_bids.each do |offer| %>
                <% meetup_digits = offer.meetup_code.to_s.rjust(4, "0").chars.first(4) %>
                <article class="profile-item-row profile-item-row--flat profile-item-row--pin-card profile-item-row--buyer-accepted profile-item-row--dashboard-linkable" role="listitem">
                  <div class="profile-item-row__top">
                    <div class="profile-item-row__identity">
                      <p class="profile-item-row__meta">
                        <span>Accepted offer</span>
                        <span><%= offer.item.category&.name || "Uncategorized" %></span>
                        <span><%= offer.created_at.strftime("%b %d, %Y") %></span>
                      </p>
                      <h3 class="profile-item-row__title"><%= offer.item.title %></h3>
                      <div class="profile-item-row__badges">
                        <span class="profile-status-badge profile-status-badge--live">ACCEPTED</span>
                        <span class="profile-status-badge profile-status-badge--neutral"><%= offer.item.college&.name || "CUHK" %></span>
                      </div>
                    </div>

                    <div class="profile-item-row__price-meta">
                      <div class="profile-item-row__summary profile-item-row__summary--tooltip">
                        <button type="button" class="profile-item-row__info-trigger" aria-label="Show meetup PIN help">
                          ?
                          <span class="profile-item-row__info-popover" role="tooltip">Show this code to the seller when you meet up to receive the item.</span>
                        </button>
                      </div>

                      <div class="profile-item-row__price-block">
                        <p class="profile-item-row__price-label">Price</p>
                        <strong class="profile-item-row__price-value"><%= display_price(offer.price) %></strong>
                      </div>
                    </div>
                  </div>

                  <div class="profile-item-row__footer profile-item-row__footer--tracking-card">
                    <div class="profile-item-row__summary">
                      <p class="profile-item-row__summary-line profile-item-row__summary-line--label">
                        Meetup PIN
                      </p>
                      <div class="profile-pin-code profile-pin-code--display" role="img" aria-label="Meetup PIN <%= offer.meetup_code %>">
                        <% meetup_digits.each do |digit| %>
                          <span class="profile-pin-code__digit profile-pin-code__digit--filled"><%= digit %></span>
                        <% end %>
                      </div>
                    </div>

                    <div class="profile-item-row__action-bar profile-item-row__action-bar--tracking">
                      <%= button_to "Cancel transaction", cancel_offer_path(offer), method: :patch, data: { turbo_confirm: "Cancel this transaction? The item will go back on the market." }, class: "market-button market-button--danger market-button--compact", form: { class: "profile-action-form" } %>
                    </div>
                  </div>
                  <%= link_to item_path(offer.item), class: "profile-item-row__dashboard-overlay-link", aria: { label: "View #{offer.item.title}" } do %>
                    <span class="item-show__screen-reader">View <%= offer.item.title %></span>
                  <% end %>
                </article>
              <% end %>
            </div>
          <% else %>
            <div class="market-empty-state">
              <p>You have no active bids right now.</p>
            </div>
          <% end %>
        </section>

      <% end %>
    </div>
  </div>
</div>
