<% content_for :title, "My Profile" %>
<% saved_pseudo = @user.pseudo_in_database || @user.display_name %>
<% pseudo_has_errors = @user.errors[:pseudo].any? %>

<div class="market-page market-page--soft profile-edit-page">
  <section class="market-page__hero profile-edit-page__hero">
    <div class="market-page__hero-inner profile-edit-page__hero-inner">
      <h1 class="market-page__title">Profile</h1>
      <p class="market-page__lede">
        Review the account details shown on your marketplace profile and update the default campus location used for distance-based features.
      </p>
      <div class="market-page__actions">
        <%= link_to "My Dashboard", dashboard_path, class: "market-button market-button--light" %>
      </div>
    </div>
  </section>

  <div class="market-page__body">
    <div class="market-split market-split--profile">
      <article class="market-surface-card market-surface-card--muted">
        <div class="market-section-heading profile-edit__section-heading">
          <div>
            <p class="market-section-eyebrow">Account snapshot</p>
            <h2 class="market-section-title">Current profile details</h2>
            <p class="market-note">These details help other students understand who they are buying from.</p>
          </div>
        </div>

        <dl class="market-data-list">
          <div class="profile-inline-edit"
               data-controller="inline-edit"
               data-inline-edit-open-value="<%= pseudo_has_errors %>"
               data-inline-edit-original-value="<%= saved_pseudo %>">
            <dt>Username</dt>
            <dd class="profile-inline-edit__detail">
              <%= form_with model: @user, url: profile_path, method: :patch, local: true, class: "profile-inline-edit__form" do |f| %>
                <div class="profile-inline-edit__row">
                  <div class="profile-inline-edit__read-row"
                       data-inline-edit-target="readView"
                       <%= "hidden" if pseudo_has_errors %>>
                    <span class="profile-inline-edit__value">
                      <%= saved_pseudo %>
                    </span>
                    <button type="button"
                            class="market-button market-button--compact profile-inline-edit__trigger"
                            data-action="inline-edit#open">
                      Edit
                    </button>
                  </div>

                  <div class="profile-inline-edit__edit-row"
                       data-inline-edit-target="editView"
                       <%= "hidden" unless pseudo_has_errors %>>
                    <%= f.text_field :pseudo,
                                     value: @user.pseudo.presence || saved_pseudo,
                                     maxlength: User::PSEUDO_MAX_LENGTH,
                                     required: true,
                                     autocomplete: "nickname",
                                     class: "market-input profile-inline-edit__input",
                                     data: { inline_edit_target: "input", action: "keydown.esc->inline-edit#close" } %>
                    <div class="profile-inline-edit__actions">
                      <%= f.submit "Save",
                                   class: "market-button market-button--compact" %>
                      <button type="button"
                              class="market-button market-button--secondary market-button--compact"
                              data-action="inline-edit#close">
                        Cancel
                      </button>
                    </div>
                  </div>
                </div>
                <p class="market-note profile-inline-edit__hint"
                   data-inline-edit-target="hint"
                   <%= "hidden" unless pseudo_has_errors %>>
                  Required, 15 characters maximum.
                </p>
                <% if pseudo_has_errors %>
                  <p class="profile-inline-edit__error" data-inline-edit-target="error"><%= @user.errors[:pseudo].first %></p>
                <% end %>
              <% end %>
            </dd>
          </div>
          <div>
            <dt>Email</dt>
            <dd><%= @user.email %></dd>
          </div>
          <div>
            <dt>College</dt>
            <dd><%= @user.college&.name || "Not specified" %></dd>
          </div>
          <div>
            <dt>Default location</dt>
            <dd><%= @user.location_display_name %></dd>
          </div>
        </dl>
      </article>

      <section class="market-surface-card">
        <div class="market-section-heading profile-edit__section-heading">
          <div>
            <p class="market-section-eyebrow">Location settings</p>
            <h2 class="market-section-title">Default campus location</h2>
            <p class="market-note">Choose where you usually meet up. Your saved location helps buyers understand distance and helps you see more relevant nearby listings.</p>
          </div>
        </div>

        <%= form_with model: @user, url: profile_path, method: :patch, local: true, class: "profile-form profile-edit__form" do |f| %>
          <div class="profile-form__section">
            <div class="profile-edit__map-shell"
                 data-controller="map-picker"
                 data-map-picker-initial-lat-value="<%= @user.latitude || 22.4172 %>"
                 data-map-picker-initial-lng-value="<%= @user.longitude || 114.2071 %>"
                 data-map-picker-zoom-value="15"
                 data-map-picker-marker-popup-value="Drag to set your location within campus"
                 data-map-picker-selection-label-value="Set your default location here">

              <div data-map-picker-target="map" class="market-map market-map--compact"></div>

              <p class="market-note profile-edit__map-note">
                Click anywhere on the campus map to store the location used for distance calculations.
              </p>

              <%= f.hidden_field :latitude, data: { map_picker_target: "latInput" } %>
              <%= f.hidden_field :longitude, data: { map_picker_target: "lngInput" } %>
              <%= f.hidden_field :default_location, data: { map_picker_target: "locationNameInput" } %>
            </div>
          </div>

          <div class="market-button-row">
            <%= f.submit "Save location", class: "market-button" %>
          </div>
        <% end %>
      </section>
    </div>
  </div>
</div>
