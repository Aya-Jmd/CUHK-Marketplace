<% page_title = current_user.admin? ? "Super Admin Dashboard" : "#{current_user.college.name} Admin Dashboard" %>
<% pending_admins = @users.count { |user| !user.setup_completed? && (user.admin? || user.college_admin?) } %>
<% content_for :title, page_title %>

<div class="market-page market-page--soft admin-page admin-page--dashboard">
  <section class="market-page__hero">
    <div class="market-page__hero-inner market-page__hero-inner--wide">
      <div class="admin-page__hero-row">
        <div>
          <p class="market-page__eyebrow">Admin Panel</p>
          <h1 class="market-page__title"><%= page_title %></h1>
          <p class="market-page__lede">
            Manage moderators, review marketplace users, and keep access controls available from one compact workspace.
          </p>
        </div>

        <div class="admin-page__role-chip">
          <span>Signed in as</span>
          <strong><%= current_user.role.humanize %></strong>
          <small><%= current_user.email %></small>
        </div>
      </div>

      <div class="market-page__actions">
        <%= link_to "Marketplace", items_path(marketplace_base_params), class: "market-button market-button--secondary" %>
        <%= link_to "Notifications", notifications_path, class: "market-button market-button--secondary" %>
        <%= link_to "Analytics", analytics_path, class: "market-button market-button--secondary" %>
        <%= link_to "Pending reports", notifications_path(category: "pending_reports", show_unread: "0"), class: "market-button market-button--secondary" %>
      </div>
    </div>
  </section>

  <div class="market-page__body market-page__body--wide">
    <div class="market-summary-grid market-summary-grid--triple">
      <article class="market-surface-card market-surface-card--muted market-summary-card">
        <p class="market-summary-card__label">Users</p>
        <strong class="market-summary-card__value"><%= @total_users %></strong>
      </article>

      <article class="market-surface-card market-surface-card--muted market-summary-card">
        <p class="market-summary-card__label">Active Listings</p>
        <strong class="market-summary-card__value"><%= @total_items %></strong>
      </article>

      <article class="market-surface-card market-surface-card--muted market-summary-card">
        <p class="market-summary-card__label">Pending Reports</p>
        <strong class="market-summary-card__value"><%= @pending_reports %></strong>
      </article>

      <article class="market-surface-card market-surface-card--muted market-summary-card">
        <p class="market-summary-card__label">Pending Admin Setups</p>
        <strong class="market-summary-card__value"><%= pending_admins %></strong>
      </article>
    </div>

    <div class="admin-dashboard">
      <aside class="market-surface-card admin-dashboard__invite">
        <div class="market-section-heading">
          <div>
            <p class="market-section-eyebrow">Invite</p>
            <h2 class="market-section-title">Add a moderator</h2>
            <p class="market-note">
              Credentials are generated server-side exactly as before. This only changes the presentation.
            </p>
          </div>
        </div>

        <%= form_with model: @new_admin, url: admin_invite_path, local: true, class: "admin-form" do |f| %>
          <div class="listing-form__field">
            <%= f.label :email, "Email address" %>
            <%= f.email_field :email, required: true, placeholder: "email@cuhk.edu.hk", class: "listing-form__input" %>
          </div>

          <div class="listing-form__field">
            <%= f.label :role, "System role" %>
            <select name="user[role]" id="user_role" class="listing-form__select">
              <% if current_user.admin? %>
                <option value="admin">Super Admin</option>
              <% end %>
              <option value="college_admin">College Admin</option>
            </select>
          </div>

          <% if current_user.admin? %>
            <div class="listing-form__field">
              <%= f.label :college_id, "Assign to college" %>
              <%= f.collection_select :college_id, @colleges, :id, :name, { prompt: "Select a college..." }, class: "listing-form__select" %>
            </div>
          <% end %>

          <%= f.submit "Generate Credentials", class: "market-button" %>
        <% end %>
      </aside>

      <section class="market-surface-card admin-dashboard__users">
        <div class="market-section-heading admin-dashboard__heading">
          <div>
            <p class="market-section-eyebrow">User Management</p>
            <h2 class="market-section-title">Accounts in scope</h2>
            <p class="market-note">
              <%= current_user.admin? ? "All colleges are shown here." : "Only users from your college are shown here." %>
            </p>
          </div>
        </div>

        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>User</th>
                <th>Role</th>
                <th>Status</th>
                <th>Joined</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @users.each do |user| %>
                <tr>
                  <td>
                    <strong><%= user.email %></strong>
                    <span><%= user.college&.name || "Global" %></span>
                  </td>
                  <td>
                    <span class="admin-table__badge admin-table__badge--<%= user.role %>">
                      <%= user.role.titleize %>
                    </span>
                  </td>
                  <td>
                    <% if user.banned? %>
                      <span class="admin-table__status admin-table__status--banned">Banned</span>
                    <% elsif user.setup_completed? %>
                      <span class="admin-table__status admin-table__status--active">Active</span>
                    <% else %>
                      <span class="admin-table__status admin-table__status--pending">Pending setup</span>
                    <% end %>
                  </td>
                  <td><%= user.created_at.strftime("%b %d, %Y") %></td>
                  <td>
                    <% if admin_manageable_user?(user) %>
                      <% if user.banned? %>
                        <%= button_to "Unban", unban_admin_user_path(user), method: :patch,
                            class: "market-button market-button--secondary market-button--compact",
                            form: { class: "admin-table__action-form" } %>
                      <% else %>
                        <%= button_to "Ban", ban_admin_user_path(user), method: :patch,
                            data: { turbo_confirm: "Ban #{user.email}?" },
                            class: "market-button market-button--danger market-button--compact",
                            form: { class: "admin-table__action-form" } %>
                      <% end %>
                    <% else %>
                      <span class="admin-table__muted">No action</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
    </div>

    <section class="market-surface-card admin-dashboard__reports">
      <div class="market-section-heading admin-dashboard__heading">
        <div>
          <p class="market-section-eyebrow">Moderation</p>
          <h2 class="market-section-title">Report queue</h2>
          <p class="market-note">
            Open the filtered notification views to resolve listing reports without losing the existing workflow.
          </p>
        </div>

        <div class="market-page__actions market-page__actions--compact">
          <%= link_to "Pending reports", notifications_path(category: "pending_reports", show_unread: "0"), class: "market-button market-button--secondary market-button--compact" %>
          <%= link_to "All reports", notifications_path(category: "all_reports", show_unread: "0"), class: "market-button market-button--secondary market-button--compact" %>
        </div>
      </div>

      <div class="market-summary-grid">
        <article class="market-surface-card market-surface-card--muted market-summary-card">
          <p class="market-summary-card__label">Reports in scope</p>
          <strong class="market-summary-card__value"><%= @total_reports %></strong>
        </article>

        <article class="market-surface-card market-surface-card--muted market-summary-card">
          <p class="market-summary-card__label">Awaiting review</p>
          <strong class="market-summary-card__value"><%= @pending_reports %></strong>
        </article>
      </div>
    </section>
  </div>
</div>
