<% summary_cards = [
  { label: "Users", value: @total_users, href: "#admin-users", hint: "View" },
  { label: "Listings", value: @total_items, href: items_path(marketplace_base_params), hint: "Open" }
] %>
<% content_for :title, "Admin panel" %>



  <div class="market-page__body market-page__body--wide">
  <div class="market-page market-page--soft admin-page admin-page--dashboard">

    <section class="market-page__hero">
      <div class="market-page__hero-inner market-page__hero-inner--wide">
        <div class="admin-page__hero-row">
          <div>
            <h1 class="market-page__title">Admin panel</h1>
          </div>
        </div>
      </div>
    </section>

    <section class="admin-dashboard__overview">
      <section class="market-surface-card admin-overview-panel">
        <div class="market-section-heading admin-overview-panel__heading">
          <div>
            <p class="market-section-eyebrow">Overview</p>
            <h2 class="market-section-title">Operational snapshot</h2>
            <p class="market-note">
              Keep the main account and marketplace signals visible in one compact row.
            </p>
          </div>
        </div>

        <div class="admin-overview-stats">
          <% summary_cards.each do |card| %>
            <%= link_to card[:href], class: "market-surface-card market-surface-card--muted market-summary-card admin-overview-stat" do %>
              <div class="admin-overview-stat__top">
                <p class="market-summary-card__label"><%= card[:label] %></p>
                <span class="admin-overview-stat__hint"><%= card[:hint] %></span>
              </div>
              <strong class="market-summary-card__value"><%= card[:value] %></strong>
            <% end %>
          <% end %>
        </div>
      </section>

      <section class="market-surface-card admin-overview-panel admin-overview-panel--reports" id="admin-reports">
        <div class="market-section-heading admin-overview-panel__heading">
          <div>
            <p class="market-section-eyebrow">Moderation</p>
            <h2 class="market-section-title">Report queue</h2>
            <p class="market-note">
              Open the report workflow directly from the overview without losing context.
            </p>
          </div>

          <div class="market-page__actions market-page__actions--compact admin-overview-actions">
          </div>
        </div>

        <div class="admin-overview-reports">
          <%= link_to notifications_path(category: "all_reports", show_unread: "0"), class: "market-surface-card market-surface-card--muted market-summary-card admin-overview-report" do %>
            <p class="market-summary-card__label">Reports in scope</p>
            <strong class="market-summary-card__value"><%= @total_reports %></strong>
          <% end %>

          <%= link_to notifications_path(category: "pending_reports", show_unread: "0"), class: "market-surface-card market-surface-card--muted market-summary-card admin-overview-report" do %>
            <p class="market-summary-card__label">Awaiting review</p>
            <strong class="market-summary-card__value"><%= @pending_reports %></strong>
          <% end %>
        </div>
      </section>
    </section>

    <div class="admin-dashboard">
      <aside class="market-surface-card admin-dashboard__invite">
        <div class="market-section-heading">
          <div>
            <p class="market-section-eyebrow">Invite</p>
            <h2 class="market-section-title">Add a moderator</h2>
            <p class="market-note">
              Create moderator access here, then use Manage invite below whenever you need to recover a pending setup pin.
            </p>
          </div>
        </div>

        <%= form_with model: @new_admin, url: admin_invite_path, local: true, class: "admin-form admin-dashboard__invite-form" do |f| %>
          <% if current_user.admin? && @rule_college.present? %>
            <%= hidden_field_tag :rule_college_id, @rule_college.id %>
          <% end %>

          <div class="listing-form__field">
            <%= f.label :email, "Email address" %>
            <%= f.email_field :email, required: true, placeholder: "email@cuhk.edu.hk", class: "listing-form__input" %>
          </div>

          <div class="listing-form__field">
            <%= f.label :role, "Admin scope" %>
            <select name="user[role]" id="user_role" class="listing-form__select">
              <% if current_user.admin? %>
                <option value="admin">Super Admin</option>
              <% end %>
              <option value="college_admin">College Admin</option>
            </select>
          </div>

          <% if current_user.admin? %>
            <div class="listing-form__field">
              <%= f.label :college_id, "Assign to college" %>
              <%= f.collection_select :college_id, @colleges, :id, :name, { prompt: "Select a college..." }, class: "listing-form__select" %>
            </div>
          <% end %>

          <%= f.submit "Generate Credentials", class: "market-button" %>
        <% end %>
      </aside>

      <section class="market-surface-card admin-dashboard__users" id="admin-users">
        <div class="market-section-heading admin-dashboard__heading">
          <div>
            <p class="market-section-eyebrow">User Management</p>
            <h2 class="market-section-title">User list</h2>
            <p class="market-note">
              <%= current_user.admin? ? "All colleges are shown here." : "Only users from your college are shown here." %>
            </p>
          </div>
        </div>

        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>User</th>
                <th>Role</th>
                <th>Status</th>
                <th>Joined</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
            
              <% @users.each do |user| %>
                <%if user!=current_user%>
                  <tr>
                    <td>
                      <strong><%= user.email %></strong>
                      <span><%= user.college&.name || "Global" %></span>
                    </td>
                    <td>
                      <span class="admin-table__badge admin-table__badge--<%= user.role %>">
                        <%= user.role.titleize %>
                      </span>
                    </td>
                    <td>
                      <% if user.banned? %>
                        <span class="admin-table__status admin-table__status--banned">Banned</span>
                      <% elsif user.setup_completed? %>
                        <span class="admin-table__status admin-table__status--active">Active</span>
                      <% else %>
                        <span class="admin-table__status admin-table__status--pending">Pending setup</span>
                      <% end %>
                    </td>
                    <td><%= user.created_at.strftime("%b %d, %Y") %></td>
                    <td>
                      <% if admin_manageable_user?(user) %>
                        <% if user.banned? %>
                          <%= button_to "Unban", unban_admin_user_path(user), method: :patch,
                              class: "market-button market-button--secondary market-button--compact",
                              form: { class: "admin-table__action-form" } %>
                        <% else %>
                          <%= button_to "Ban", ban_admin_user_path(user), method: :patch,
                              data: { turbo_confirm: "Ban #{user.email}?" },
                              class: "market-button market-button--danger market-button--compact",
                              form: { class: "admin-table__action-form" } %>
                        <% end %>
                      <% else %>
                        <span class="admin-table__muted">No action</span>
                      <% end %>
                    </td>
                  </tr>
                <%end%>
              <% end %>

            </tbody>
          </table>
        </div>

      </section>

      <div class="admin-dashboard__invite-tools">
        <section class="market-surface-card admin-dashboard__invite-access" id="admin-invite-access">
          <div class="market-section-heading">
            <div>
              <p class="market-section-eyebrow">Manage invite</p>
              <h2 class="market-section-title">Invite access</h2>
            </div>
          </div>

          <div class="admin-invite-access__panel">
            <p class="admin-invite-access__hint">Enter your password to see invites</p>

            <%= form_with url: admin_reveal_invites_path, method: :post, local: true, class: "admin-form admin-invite-access__form" do %>
              <% if current_user.admin? && @rule_college.present? %>
                <%= hidden_field_tag :rule_college_id, @rule_college.id %>
              <% end %>

              <div class="listing-form__field">
                <%= label_tag :invite_access_password, "Current password" %>
                <%= password_field_tag "invite_access[password]",
                    nil,
                    id: "invite_access_password",
                    required: true,
                    autocomplete: "current-password",
                    placeholder: "Enter your password",
                    class: "listing-form__input" %>
              </div>

              <%= submit_tag "Show invites", class: "market-button market-button--secondary" %>
            <% end %>
          </div>
        </section>

        <% if @invite_results_visible %>
          <section class="market-surface-card admin-dashboard__invite-results" id="admin-pending-invites" data-turbo-temporary>
            <div class="market-section-heading admin-dashboard__heading">
              <div>
                <p class="market-section-eyebrow">Pending invites</p>
                <h2 class="market-section-title">Setup pins</h2>
                <p class="market-note">
                  Only unfinished invites that you created appear here. Refresh again to hide this list.
                </p>
              </div>
            </div>

            <% if @revealed_invites.any? %>
              <div class="admin-invite-list" role="list">
                <% @revealed_invites.each do |invite| %>
                  <article class="admin-invite-card" role="listitem">
                    <p class="admin-invite-card__eyebrow">Invited administrator</p>
                    <strong class="admin-invite-card__email"><%= invite[:user].email %></strong>

                    <div class="admin-invite-card__details">
                      <div class="admin-invite-card__detail">
                        <span class="admin-invite-card__detail-label">College</span>
                        <span class="admin-invite-card__detail-value"><%= invite[:college_name] %></span>
                      </div>

                      <div class="admin-invite-card__detail admin-invite-card__detail--pin">
                        <span class="admin-invite-card__detail-label">Setup pin</span>
                        <code class="admin-invite-card__pin"><%= invite[:setup_pin] %></code>
                      </div>
                    </div>
                  </article>
                <% end %>
              </div>
            <% else %>
              <div class="admin-invite-table__empty">
                No unfinished invites are assigned to you right now.
              </div>
            <% end %>
          </section>
        <% end %>
      </div>

      <section class="market-surface-card admin-dashboard__college">
        <% rules_note =
            if current_user.admin?
              "Choose a college, then set the listing rules that apply to its users."
            elsif @rule_college.present?
              "These rules apply to every user in #{@rule_college.name}."
            else
              "No college is available to manage yet."
            end %>
        <div class="market-section-heading admin-dashboard__heading">
          <div>
            <p class="market-section-eyebrow">College Management</p>
            <h2 class="market-section-title">College rules</h2>
            <p class="market-note"><%= rules_note %></p>
          </div>
        </div>

        <div class="admin-rules">
          <% if @rule_college.present? %>
            <% if current_user.admin? %>
              <%= form_with url: admin_root_path, method: :get, local: true, class: "admin-form admin-rules__selector-form" do %>
                <div class="market-form-field">
                  <%= label_tag :rule_college_id, "College" %>
                  <%= select_tag :rule_college_id,
                      options_from_collection_for_select(@rule_college_options, :id, :name, @rule_college.id),
                      class: "listing-form__select",
                      onchange: "this.form.requestSubmit()" %>
                </div>
              <% end %>
            <% end %>

            <%= form_with model: @rule_college, url: admin_college_rules_path, method: :patch, local: true, class: "admin-form admin-rules__form" do |f| %>
              <% if current_user.admin? %>
                <%= hidden_field_tag :college_id, @rule_college.id %>
              <% end %>

              <div class="admin-rules__row">
                <div class="admin-rules__copy">
                  <%= f.label :max_item_price, "Max item price", class: "admin-rules__label" %>
                  <p class="market-note">
                    Users in <%= @rule_college.name %> cannot publish listings above this amount.
                  </p>
                </div>
                <div class="admin-rules__control">
                  <%= f.number_field :max_item_price,
                      step: "0.01",
                      min: 0.01,
                      max: Currency.convert_from_hkd(Item::MAX_PRICE_HKD, current_currency_code),
                      value: admin_rule_price_value(@rule_college),
                      class: "market-input" %>
                </div>
              </div>

              <div class="admin-rules__row">
                <div class="admin-rules__copy">
                  <%= f.label :max_items_per_user, "Max number of items a user can post", class: "admin-rules__label" %>
                  <p class="market-note">
                    Active and reserved listings count toward this limit.
                  </p>
                </div>
                <div class="admin-rules__control">
                  <%= f.number_field :max_items_per_user,
                      step: 1,
                      min: 1,
                      class: "market-input" %>
                </div>
              </div>

              <%= f.submit "Save college rules", class: "market-button" %>
            <% end %>
          <% end %>
        </div>
      </section>
    </div>
  </div>
</div>
