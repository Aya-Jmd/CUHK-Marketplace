<div style="max-width: 1200px; margin: 0 auto; padding: 24px;">
  <h1 style="margin-top: 0;">CHAT</h1>

  <div style="display: flex; gap: 20px; align-items: stretch; min-height: 70vh;">
    <aside style="width: 32%; min-width: 280px; border: 1px solid #ddd;">
      <% if @conversations.any? %>
        <% @conversations.each do |conversation| %>
          <% last_message = conversation.last_message %>
          <% other_user = conversation.other_user_for(current_user) %>
          <% selected = conversation == @current_conversation %>

          <%= link_to conversations_path(conversation_id: conversation.id),
              style: "display: block; padding: 14px 16px; border-bottom: 1px solid #eee; text-decoration: none; color: inherit; background: #{selected ? '#f5f5f5' : 'white'};" do %>
            <div style="font-weight: 700; margin-bottom: 6px;">
              <%= "#{other_user.display_name}, #{conversation.item.title}" %>
            </div>
            <div style="font-size: 0.9em; color: #555;">
              <% if last_message.present? %>
                <%= "#{last_message.user.display_name}: #{truncate(last_message.content, length: 55)}" %>
                <span style="float: right;"><%= last_message.created_at.strftime("%H:%M") %></span>
              <% else %>
                &lt;empty conversation&gt;
              <% end %>
            </div>
          <% end %>
        <% end %>
      <% else %>
        <div style="padding: 16px;">No conversations yet.</div>
      <% end %>
    </aside>

    <section style="flex: 1; border: 1px solid #ddd; padding: 16px;">
      <% if @current_conversation.present? %>
        <% other_user = @current_conversation.other_user_for(current_user) %>
        <div style="padding-bottom: 12px; border-bottom: 1px solid #eee; margin-bottom: 16px;">
          <strong><%= other_user.display_name %></strong>
          <div style="color: #666; margin-top: 4px;"><%= @current_conversation.item.title %></div>
        </div>

        <%= turbo_stream_from @current_conversation %>

        <!-- ADDING data-controller ==> for autoscrolling mechanism ? -->
        <div id="messages" data-controller="chat-scroll" style="height: 55vh; overflow-y: auto; border: 1px solid #eee; padding: 12px; margin-bottom: 16px;">
          <%= render @messages %>
        </div>

        <%= render "messages/form", conversation: @current_conversation, message: @message %>
      <% else %>
        <p>Select a conversation to start chatting.</p>
      <% end %>
    </section>
  </div>
</div>
