<% content_for :title, "Conversations" %>

<div class="market-page market-page--soft chat-page">
  <%= turbo_stream_from current_user, :conversation_inbox %>
  <section class="market-page__hero">
    <div class="market-page__hero-inner market-page__hero-inner--wide">
      <h1 class="market-page__title">Conversations</h1>
    </div>
  </section>

  <div class="market-page__body market-page__body--wide">
    <div class="chat-page__layout">
      <aside class="market-surface-card chat-page__threads"
             data-controller="conversation-filter"
             data-conversation-filter-current-conversation-id-value="<%= @current_conversation&.id %>">
        <div class="chat-page__threads-head">
          <h2 class="chat-page__section-title">All chats</h2>
          <%= render "thread_count", user: current_user %>
        </div>

        <% if @conversations.any? %>
          <div class="chat-page__thread-search">
            <input type="search"
                class="chat-page__thread-search-input"
                placeholder="Search by person, listing, or message"
                aria-label="Search conversations"
                autocomplete="off"
                data-conversation-filter-target="input"
                data-action="input->conversation-filter#filter keyup->conversation-filter#filter change->conversation-filter#filter search->conversation-filter#filter">
          </div>

          <div id="conversation_threads_<%= current_user.id %>" class="chat-page__thread-list">
            <%= render partial: "thread",
                collection: @conversations,
                as: :conversation,
                locals: { current_user: current_user, current_conversation: @current_conversation } %>
          </div>

          <p class="chat-page__thread-empty" data-conversation-filter-target="empty" hidden>
            No conversations match that search.
          </p>
        <% else %>
          <div class="market-empty-state">
            <p>No conversations yet.</p>
          </div>
        <% end %>
      </aside>

      <section class="market-surface-card chat-page__panel">
        <% if @current_conversation.present? %>
          <% other_user = @current_conversation.other_user_for(current_user) %>
          <% viewer_role = current_user == @current_conversation.buyer ? "buyer" : "seller" %>
          <div class="chat-page__panel-head">
            <div class="chat-page__panel-copy" data-conversation-role="<%= viewer_role %>">
              <h2 class="chat-page__section-title">
                <%= link_to other_user.display_name, user_path(other_user), class: "chat-page__person-link" %>
              </h2>
              <%= render "offer_value", conversation: @current_conversation, offer: @current_offer %>
            </div>

            <%= link_to item_path(@current_conversation.item, marketplace_base_params),
                class: "chat-page__listing-card chat-page__listing-card--link" do %>
              <% if @current_conversation.item.images.attached? %>
                <%= image_tag @current_conversation.item.images.first.variant(resize_to_fill: [120, 120]),
                    class: "chat-page__listing-media",
                    alt: @current_conversation.item.title %>
              <% else %>
                <div class="chat-page__listing-placeholder" aria-hidden="true">
                  <%= @current_conversation.item.title.first.to_s.upcase %>
                </div>
              <% end %>

              <div class="chat-page__listing-copy">
                <p class="chat-page__listing-eyebrow">Listing</p>
                <strong class="chat-page__listing-title"><%= @current_conversation.item.title %></strong>
                <div class="chat-page__listing-meta">
                  <span class="chat-page__listing-price"><%= display_price(@current_conversation.item.price) %></span>
                  <span class="chat-page__listing-status"><%= @current_conversation.item.status.presence&.humanize || "Available" %></span>
                </div>
              </div>
            <% end %>
          </div>

          <%= turbo_stream_from @current_conversation %>

          <div data-controller="chat-scroll" class="chat-page__messages-shell">
            <div id="messages" data-chat-scroll-target="viewport" class="chat-page__messages">
              <%= render @messages %>
            </div>

            <div class="chat-page__custom-scrollbar"
                 data-chat-scroll-target="track"
                 data-action="pointerdown->chat-scroll#trackPointerDown"
                 hidden
                 aria-hidden="true">
              <div class="chat-page__custom-scrollbar-thumb"
                   data-chat-scroll-target="thumb"
                   data-action="pointerdown->chat-scroll#thumbPointerDown"></div>
            </div>
          </div>

          <%= render "messages/form", conversation: @current_conversation, message: @message %>
        <% else %>
          <div class="market-empty-state">
            <p>Select a conversation to start chatting.</p>
          </div>
        <% end %>
      </section>
    </div>
  </div>
</div>
