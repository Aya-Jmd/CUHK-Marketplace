<div style="font-family: sans-serif; max-width: 600px; margin: 0 auto; border: 1px solid #e1e8ed; border-radius: 12px; overflow: hidden;">
  <div style="background: linear-gradient(135deg, #6c5ce7, #a29bfe); padding: 30px; text-align: center; color: white;">
    <h1 style="margin: 0;">New Offer Received! 🎉</h1>
  </div>
  <div style="padding: 30px;">
    <p>Hi <strong><%= @seller.display_name %></strong>,</p>
    <p><strong><%= @buyer.display_name %></strong> has just made an offer on your item:</p>
    
    <div style="background-color: #f8f9fa; border-left: 4px solid #6c5ce7; padding: 15px; margin: 20px 0;">
      <h3 style="margin: 0 0 10px 0;"><%= @item.title %></h3>
      <p style="margin: 0; font-size: 20px; color: #e15f41; font-weight: bold;">
        Offered Price: HK$<%= @offer.price.to_i %>
      </p>
    </div>

    <div style="text-align: center; margin-top: 30px;">
      <%= link_to "Review Offer in Dashboard", profile_url, style: "background-color: #0984e3; color: white; text-decoration: none; padding: 14px 28px; border-radius: 8px; font-weight: bold; display: inline-block;" %>
    </div>
  </div>
</div>