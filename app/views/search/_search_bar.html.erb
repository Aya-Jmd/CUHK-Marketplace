<div class="search-bar-container">
  <%= form_with url: search_path, method: :get, local: true, class: "flex gap-2" do %>
    <% if params[:category_id].present? %>
      <%= hidden_field_tag :category_id, params[:category_id] %>
    <% end %>

    <%= hidden_field_tag :scope, marketplace_scope %>
    <%= text_field_tag :q, params[:q], placeholder: "Search items...", class: "form-control" %>
    <%= submit_tag "Search", class: "btn btn-primary" %>
  <% end %>
</div>
