<% base_search_state = search_filter_state(
    query: @query,
    scope: @scope,
    sort: @sort,
    selected_category: @selected_category,
    price_filter_active: @price_filter_active,
    min_price: @min_price,
    max_price: @max_price,
    price_currency: current_currency_code
  ) %>

<div class="search-results-page">
  <section class="search-results-page__hero" aria-hidden="true"></section>

  <div class="items-main search-results-page__shell">
    <%= render "items/category_strip",
        categories: @categories,
        selected_category: @selected_category,
        base_state: base_search_state %>

    <div class="search-results-page__layout">
      <%= render "search/filter_sidebar",
          categories: @categories,
          selected_category: @selected_category,
          sort: @sort,
          base_state: base_search_state,
          min_price: @min_price,
          max_price: @max_price,
          price_floor: @price_floor,
          price_ceiling: @price_ceiling,
          price_currency: current_currency_code,
          price_filter_active: @price_filter_active %>

      <section class="search-results-page__content" aria-label="Search results">
        <%= render "search/results_summary",
            query: @query,
            selected_category: @selected_category,
            result_count: @results.size,
            sort: @sort,
            scope: @scope,
            price_filter_active: @price_filter_active %>

        <% if @results.present? %>
          <%= render "items/market_grid", items: @results, grid_class: "search-results-page__grid" %>
        <% else %>
          <div class="search-results-page__empty">
            <span>Try another keyword, switch category, or broaden the side filters.</span>
          </div>
        <% end %>
      </section>
    </div>
  </div>
</div>
