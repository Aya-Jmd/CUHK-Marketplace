<% categories = local_assigns.fetch(:categories, []) %>
<% selected_category = local_assigns[:selected_category] %>
<% sort = local_assigns[:sort] || "recent" %>
<% base_state = local_assigns.fetch(:base_state, {}) %>
<% min_price = local_assigns[:min_price] %>
<% max_price = local_assigns[:max_price] %>
<% price_floor = local_assigns[:price_floor] %>
<% price_ceiling = local_assigns[:price_ceiling] %>
<% price_steps = local_assigns[:price_steps] || [ price_floor, price_ceiling ].compact.uniq.sort %>
<% price_currency = local_assigns[:price_currency] %>
<% price_active = local_assigns[:price_filter_active] %>
<% query = base_state[:q] %>
<% clear_all_path = search_clear_path(query, base_state[:scope]) %>
<% reset_price_path = search_state_path(base_state.except(:price_currency, :min_price, :max_price)) %>

<aside class="search-results-page__sidebar" aria-label="Search filters">
  <div class="search-results-page__sidebar-card" data-controller="filter-state custom-scrollbar">
    <div class="search-results-page__sidebar-scroll" data-custom-scrollbar-target="viewport">
      <div class="search-results-page__sidebar-header">
        <h2 class="search-results-page__sidebar-title">Filter options</h2>
        <% if search_active_filters?(selected_category: selected_category, sort: sort, price_filter_active: price_active) %>
          <%= link_to "Clear all", clear_all_path, class: "search-results-page__sidebar-clear" %>
        <% end %>
      </div>

      <details class="search-results-page__filter-group" data-filter-state-target="group" data-filter-state-key="price">
        <summary class="search-results-page__filter-summary">Price</summary>
        <div class="search-results-page__filter-list">
          <%= form_with url: search_path, method: :get, local: true, id: "search-price-filter-form" do %>
            <%= render "search/price_filter",
                base_state: base_state,
                min_price: min_price,
                max_price: max_price,
                price_floor: price_floor,
                price_ceiling: price_ceiling,
                price_steps: price_steps,
                price_currency: price_currency,
                reset_path: reset_price_path %>
          <% end %>
        </div>
      </details>

      <details class="search-results-page__filter-group" data-filter-state-target="group" data-filter-state-key="sort">
        <summary class="search-results-page__filter-summary">Sort by</summary>
        <div class="search-results-page__filter-list">
          <% search_sort_options.each do |label, value| %>
            <%= link_to label,
                search_state_path(base_state, sort: value),
                class: class_names("search-results-page__filter-link", { "is-active" => sort == value }) %>
          <% end %>
        </div>
      </details>

      <details class="search-results-page__filter-group" data-filter-state-target="group" data-filter-state-key="category">
        <summary class="search-results-page__filter-summary">Category</summary>
        <div class="search-results-page__filter-list">
          <%= link_to "All categories",
              search_state_path(base_state, category_id: nil),
              class: class_names("search-results-page__filter-link", { "is-active" => selected_category.blank? }) %>

          <% categories.each do |category| %>
            <%= link_to category.name,
                search_state_path(base_state, category_id: category.id),
                class: class_names("search-results-page__filter-link", { "is-active" => selected_category&.id == category.id }) %>
          <% end %>
        </div>
      </details>
    </div>

    <div class="search-results-page__custom-scrollbar"
         data-custom-scrollbar-target="track"
         data-action="pointerdown->custom-scrollbar#trackPointerDown"
         hidden
         aria-hidden="true">
      <div class="search-results-page__custom-scrollbar-thumb"
           data-custom-scrollbar-target="thumb"
           data-action="pointerdown->custom-scrollbar#thumbPointerDown"></div>
    </div>
  </div>
</aside>
