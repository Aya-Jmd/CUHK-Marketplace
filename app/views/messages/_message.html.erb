<% if message.marketplace_notice? %>
  <article class="chat-offer-notice">
    <p class="chat-offer-notice__text">
      <% case message.marketplace_notice_type %>
      <% when "offer_updated" %>
        <strong><%= message.user.display_name %></strong>
        made a
        <strong><%= display_price(message.offer_update_amount_hkd) %></strong>
        offer.
      <% when "offer_accepted" %>
        <strong><%= message.user.display_name %></strong>
        accepted the offer for this item.
      <% when "offer_cancelled" %>
        <strong><%= message.user.display_name %></strong>
        cancelled the transaction. The item may be available again.
      <% when "offer_completed" %>
        <strong><%= message.user.display_name %></strong>
        completed the transaction. This item is sold.
      <% end %>
    </p>
  </article>
<% else %>
  <div class="chat-message"
       data-controller="chat-message"
       data-message-user-id="<%= message.user_id %>">
    <div class="chat-message__meta">
      <strong><%= message.user.display_name %></strong>
      <time datetime="<%= message.created_at.iso8601 %>" title="<%= message.created_at.strftime("%B %d, %Y %H:%M") %>">
        <%= message.created_at.strftime("%H:%M") %>
      </time>
    </div>

    <div class="chat-message__body"><%= message.content %></div>
  </div>
<% end %>
