<%= form_with model: [conversation, message], id: "new_message_form" do |form| %>
  <div>
    <%= form.text_area :content,
        placeholder: "Type a message...",
        required: true,
        rows: 3,
        style: "width: 100%; margin-bottom: 10px;" %>
  </div>

  <%= form.submit "Send", style: "padding: 8px 16px; cursor: pointer;" %>
<% end %>
