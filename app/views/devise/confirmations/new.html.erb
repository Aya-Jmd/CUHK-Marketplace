<% content_for :title, "Resend Confirmation" %>

<div class="auth-shell">
  <section class="auth-card auth-card--narrow">
    <div class="auth-card__hero">
      <p class="auth-card__eyebrow">Verification</p>
      <h1 class="auth-card__title">Resend confirmation email</h1>
      <p class="auth-card__copy">
        If your confirmation email expired or went missing, request a new one here.
      </p>
    </div>

    <div class="auth-card__panel">
      <%= form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post, class: "auth-form" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="auth-form__field">
          <%= f.label :email %>
          <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email),
              class: "auth-form__input" %>
        </div>

        <%= f.submit "Resend confirmation instructions", class: "market-button" %>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </section>
</div>
