<h2>Sign up</h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field">
    <p><%= f.label :email %></p>
    <p><%= f.email_field :email, autofocus: true, autocomplete: "email" %></p>
  </div>

  <div class="field">
    <p><%= f.label :password %></p>
    <% if @minimum_password_length %>
      <p><em>(<%= @minimum_password_length %> characters minimum)</em></p>
    <% end %>
    <p><%= f.password_field :password, autocomplete: "new-password" %></p>
  </div>

  <div class="field">
    <p><%= f.label :password_confirmation %></p>
    <p><%= f.password_field :password_confirmation, autocomplete: "new-password" %></p>
  </div>

  <div class="field">
    <%= f.label :college, "Select your CUHK College" %><br />
    <%= f.collection_select :college_id, College.all, :id, :name, prompt: "Choose a college..." %>
  </div>

  <!-- Add location map for user -->
  <div class="field">
    <%= f.label :default_location, "Your Location (click on map to set where you usually are)", style: "display: block" %><br />
  
    <div data-controller="map-picker"
       data-map-picker-initial-lat-value="22.4172"
       data-map-picker-initial-lng-value="114.2071"
       data-map-picker-zoom-value="15">
    
      <div data-map-picker-target="map" style="height: 250px; width: 100%; border-radius: 8px; border: 1px solid #ccc;"></div>
    
      <p class="location-hint" style="font-size: 12px; color: #666; margin-top: 5px;">
      📍 Click on the map to set your default pickup location
      </p>
    
      <%= f.hidden_field :latitude, data: { map_picker_target: "latInput" } %>
      <%= f.hidden_field :longitude, data: { map_picker_target: "lngInput" } %>
      <%= f.hidden_field :default_location, data: { map_picker_target: "locationNameInput" } %>
     </div>
    </div>

  <div class="actions">
    <%= f.submit "Sign up" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
