<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Cuhk Marketplace" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Cuhk Marketplace">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%# JS library for linear two sided slider %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/nouislider@15.8.1/dist/nouislider.min.css">
    <script src="https://cdn.jsdelivr.net/npm/nouislider@15.8.1/dist/nouislider.min.js"></script>

    <%# Leaflet CSS and JS for maps %>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <%# Custom map styling %>
    <style>
      .map-container {
        margin: 15px 0;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #ddd;
      }
      .map-view {
        height: 300px;
        width: 100%;
      }
      .location-hint {
        font-size: 12px;
        color: #666;
        margin-top: 5px;
      }
    </style>
  </head>

  <body data-theme="<%= marketplace_theme_name %>"
        data-controller="notification"
        data-notification-currency-code-value="<%= current_currency_code %>">
    
    <div data-notification-target="toast" 
         class="hidden fixed top-4 right-4 bg-blue-600 text-white px-6 py-3 rounded shadow-lg z-50 transition-opacity duration-300">
    </div>


    <!-- Render the shared navigation bar everywhere, at top of page -->
    <%= render "general/header" %>
    
    <div id="flash-messages" style="max-width: 1200px; margin: 15px auto 0; padding: 0 20px;">
      <% if notice %>
        <div style="background-color: #d4edda; color: #155724; padding: 12px 20px; border-radius: 8px; margin-bottom: 15px; border: 1px solid #c3e6cb; font-weight: bold;">
          ✅ <%= notice %>
        </div>
      <% end %>

      <% if alert %>
        <div style="background-color: #f8d7da; color: #721c24; padding: 12px 20px; border-radius: 8px; margin-bottom: 15px; border: 1px solid #f5c6cb; font-weight: bold;">
          ⚠️ <%= alert %>
        </div>
      <% end %>
    </div>
    <%= yield %>

    <% if Rails.env.development? %>
      <div style="position: fixed; bottom: 100px; right: 25px; z-index: 9999;">
        <button onclick="window.open('/letter_opener', 'MailPopup', 'width=850,height=700,left=250,top=150,menubar=no,toolbar=no,location=no,status=no');" 
                style="background: linear-gradient(135deg, #ff4757 0%, #ff6b81 100%); color: white; border: none; border-radius: 50%; width: 65px; height: 65px; font-size: 28px; box-shadow: 0 6px 16px rgba(255, 71, 87, 0.4); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: transform 0.2s;" 
                onmouseover="this.style.transform='scale(1.1)'" 
                onmouseout="this.style.transform='scale(1)'">
          📧
        </button>
      </div>
    <% end %>
  </body>
</html>
