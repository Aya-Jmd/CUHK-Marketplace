<article class="market-card" role="listitem"> <!-- item comes from _markt_grid.html.erb parent -->
  <%= link_to item_path(item), class: "market-card__link" do %>
    <div class="market-card__media">
      <span class="market-card__placeholder" aria-hidden="true"></span>
      <span class="market-card__price"><%= market_card_price(item) %></span>
    </div>
    <div class="market-card__body">
      <p class="market-card__meta"><%= market_card_meta(item) %></p>
      <h3 class="market-card__title"><%= item.title %></h3>
      <p class="market-card__excerpt">
        <%= item.description.presence || "No description provided." %>
      </p>
    </div>
  <% end %>
</article>
