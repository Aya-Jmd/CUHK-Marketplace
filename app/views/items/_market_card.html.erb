<% category_label = item.category&.name.presence || "Uncategorized" %>
<% college_label = item.college&.name.presence || "CUHK" %>
<% card_price = market_card_price(item) %>

<article class="market-card" role="listitem"> 
  <%= link_to item_path(item, marketplace_base_params), class: "market-card__link" do %>
    <div class="market-card__media">
      <% if item.images.attached? %>
        <%= image_tag item.images.first.variant(resize_to_fill: [400, 300]), class: "market-card__image", alt: item.title %>
      <% else %>
        <span class="market-card__placeholder" aria-hidden="true">
          <span class="market-card__placeholder-badge">Listing</span>
          <strong class="market-card__placeholder-initials"><%= item_placeholder_initials(item) %></strong>
        </span>
      <% end %>
    </div>

    <div class="market-card__body">
      <div class="market-card__badges">
        <span class="market-card__badge market-card__badge--category"><%= category_label %></span>
        <span class="market-card__badge market-card__badge--location"><%= college_label %></span>
      </div>

      <h3 class="market-card__title"><%= item.title %></h3>

      <div class="market-card__footer">
        <span class="market-card__price <%= "market-card__price--empty" if card_price.blank? %>">
          <%= card_price.presence || "Price pending" %>
        </span>
        <span class="market-card__age"><%= market_card_age(item) %></span>
      </div>
    </div>
  <% end %>
</article>
