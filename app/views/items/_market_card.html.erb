<article class="market-card" role="listitem"> 
  <%= link_to item_path(item, marketplace_base_params), class: "market-card__link" do %>
    <div class="market-card__media">
      
      <% if item.images.attached? %>
        <%= image_tag item.images.first.variant(resize_to_fill: [400, 300]), class: "market-card__image", style: "width: 100%; height: 200px; object-fit: cover;" %>
      <% else %>
        <span class="market-card__placeholder" aria-hidden="true" style="height: 200px; display: block; background-color: #f0f0f0;"></span>
      <% end %>
      <span class="market-card__price"><%= market_card_price(item) %></span>
    </div>
    <div class="market-card__body">
      <p class="market-card__meta"><%= market_card_meta(item) %></p>
      <h3 class="market-card__title"><%= item.title %></h3>
      <p class="market-card__excerpt">
        <%= item.description.presence || "No description provided." %>
      </p>
    </div>
  <% end %>
</article>
