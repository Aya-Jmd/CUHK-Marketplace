<% content_for :title, "CUHK Marketplace" %>
<% browse_state = marketplace_base_params(@scope) %>
<% if @price_filter_active %>
  <% browse_state[:price_currency] = current_currency_code %>
  <% browse_state[:min_price] = @min_price %>
  <% browse_state[:max_price] = @max_price %>
<% end %>

<div class="items-index <%= "items-index--floating-nav" if user_signed_in? %>">

  <section class="items-hero" aria-label="Welcome">
    <div class="items-hero__inner">
      <h1 class="items-hero__title">Welcome to CUHK Marketplace</h1>
      <p class="items-hero__lede">
        The trusted platform for buying and selling second-hand items on campus.
      </p>
      <%= link_to "Post a New Item", new_item_path, class: "items-hero__cta" %>
    </div>
  </section>

  <div class="items-main">
    <p class="items-index-strip">What are you looking for ?</p>
    <%= render "items/category_strip", categories: @categories, base_state: browse_state %>




    <%= render "items/market_grid", items: @items, dom_id: "items" %>
  </div>
</div>
