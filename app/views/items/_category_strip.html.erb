<% categories = local_assigns.fetch(:categories, []) %>
<% selected_category = local_assigns[:selected_category] %>
<% base_state = local_assigns.fetch(:base_state, {}) %>
<% all_categories_state = base_state.except(:category_id) %>

<% current_scope = marketplace_scope %>
<% admin_viewer = current_user&.admin? %>
<% signed_in_viewer = current_user.present? %>


  <% if admin_viewer %>
    <% scope_form_url = controller.controller_name == "search" && controller.action_name == "index" ? search_path : items_path %>
    <% college_options = [["CUHK Global", ""]] + College.order(:name).pluck(:name, :id) %>
  <% elsif signed_in_viewer %>
    <% next_scope = current_scope == "college" ? "all" : "college" %>
    <% current_scope_label = marketplace_scope_label(current_scope) %>
    <% next_scope_label = marketplace_scope_label(next_scope) %>
  <% end %>

<% if categories.present? %>
  <section class="items-category-strip" aria-label="Browse categories">
    <div class="items-category-strip__grid">

      <% if admin_viewer %>
        <div class="site-header__scope-switch">
          <%= form_with url: scope_form_url, method: :get, local: true, class: "site-header__scope-form" do %>
            <%= hidden_field_tag :q, params[:q] if params[:q].present? %>
            <%= hidden_field_tag :category_id, params[:category_id] if params[:category_id].present? %>
            <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
            <%= hidden_field_tag :price_currency, params[:price_currency] if params[:price_currency].present? %>
            <%= hidden_field_tag :min_price, params[:min_price] if params[:min_price].present? %>
            <%= hidden_field_tag :max_price, params[:max_price] if params[:max_price].present? %>

            <%= select_tag :college_scope_id,
                options_for_select(college_options, params[:college_scope_id]),
                class: "site-header__scope-select",
                onchange: "this.form.requestSubmit()" %>
          <% end %>
        </div>
      <% elsif signed_in_viewer %>
        <nav class="site-header__scope-switch" aria-label="Marketplace scope">
          <%= link_to marketplace_scope_switch_path(next_scope),
              class: class_names("site-header__scope-toggle", { "is-college" => current_scope == "college" }),
              aria: { label: "Switch marketplace scope to #{next_scope_label}" },
              title: "Switch to #{next_scope_label}" do %>
            <span class="site-header__scope-toggle-text"><%= current_scope_label %></span>
            <span class="site-header__scope-toggle-track" aria-hidden="true">
              <span class="site-header__scope-toggle-thumb"></span>
            </span>
          <% end %>
        </nav>
      <% end %>

      <% categories.each do |category| %>
        <% is_selected = selected_category&.id == category.id %>
        <% path_params = is_selected ? all_categories_state : all_categories_state.merge(category_id: category.id) %>

        <%= link_to category.name,
            search_path(path_params),
            class: class_names("items-category-strip__item", { "is-active" => is_selected }) %>
      <% end %>
    </div>
  </section>
<% end %>
