<%= render "shared/price_range_filter",
    min_price: @min_price,
    max_price: @max_price,
    price_floor: @price_floor,
    price_ceiling: @price_ceiling,
    price_currency: current_currency_code,
    hidden_fields: { price_currency: current_currency_code, scope: @scope },
    reset_path: items_path(scope: @scope),
    auto_submit: false,
    show_apply: true %>
