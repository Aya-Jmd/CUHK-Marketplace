<%= form_with(model: item) do |form| %>
  <% if item.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(item.errors.count, "error") %> prohibited this item from being saved:</h2>

      <ul>
        <% item.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, style: "display: block" %>
    <%= form.text_field :title %>
  </div>

  <div>
    <%= form.label :price, "Price (#{current_currency_code})", style: "display: block" %>
    <%= form.text_field :price, value: item.price.present? ? Currency.convert_from_hkd(item.price, current_currency_code) : nil %>
  </div>

  <div>
    <%= form.label :description, style: "display: block" %>
    <%= form.textarea :description %>
  </div>

  <div>
    <%= form.label :category_id, "Select a Category", style: "display: block" %>
    <%= form.collection_select :category_id, Category.sorted_for_dropdown, :id, :name, prompt: "Choose a category..." %>
  </div>

  <div>
    <%= form.label :is_global, "Make this item visible to all CUHK colleges? (Global)", style: "display: block" %>
    <%= form.check_box :is_global %>
  </div>

  <!-- Interactive Map for Location Picker -->
  <div class="field">
    <%= form.label :location, "Item Location (Click on map to set)", style: "display: block" %>
    
    <div data-controller="map-picker"
         data-map-picker-initial-lat-value="22.4172"
         data-map-picker-initial-lng-value="114.2071"
         data-map-picker-zoom-value="16">
      
      <div data-map-picker-target="map" class="map-view" style="height: 300px; width: 100%; border-radius: 8px; border: 1px solid #ccc;"></div>
      
      <p class="location-hint">📍 Click on the map or drag the marker to set your item's pickup location</p>
      
      <!-- Hidden fields to store coordinates -->
      <%= form.hidden_field :latitude, data: { map_picker_target: "latInput" } %>
      <%= form.hidden_field :longitude, data: { map_picker_target: "lngInput" } %>
      <%= form.hidden_field :location_name, data: { map_picker_target: "locationNameInput" } %>
    </div>
  </div>
  <div style="margin-bottom: 20px; margin-top: 20px;">
    <%= form.label :images, "Item Photos (You can select multiple)", style: "display: block; font-weight: bold; margin-bottom: 5px;" %>
    <%= form.file_field :images, multiple: true, accept: "image/png, image/jpeg, image/jpg, image/webp", style: "width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;" %>
    <p style="font-size: 0.8em; color: #666; margin-top: 4px;">Supported formats: JPG, PNG, WEBP</p>
  </div>
  <div>
    <%= form.submit %>
  </div>
<% end %>
