<p style="color: green"><%= notice %></p>

<div>
  Offer posted by
  <strong>
    <% if @item.user.present? %>
      <%= link_to (current_user == @item.user ? "you" : @item.user.email),
                  user_path(@item.user) %>
    <% else %>
      <em>Unknown user</em>
    <% end %>
  </strong>,
  on <%= @item.created_at.strftime("%B %d, %Y at %I:%M %p") %>.
</div>

<br>

<%= render @item %>

<%# ===================== LOCATION SECTION ===================== %>
<% if @item.latitude.present? && @item.longitude.present? %>
  <div style="margin: 20px 0; padding: 15px; background: #f9f9f9; border-radius: 8px;">

    <h3>📍 Pickup Location</h3>

    <% if user_signed_in? && current_user.has_location? && @distance.present? %>
      <div style="background: #e8f5e9; padding: 10px; border-radius: 8px; margin-bottom: 15px;">
        <strong>📏 Distance from your location:</strong>
        <span style="font-size: 18px; font-weight: bold; color: #2e7d32;">
          <%= @distance %> km
        </span>
        <span style="display: block; font-size: 14px; color: #666;">
          <%= @distance_text %>
        </span>
      </div>
    <% elsif user_signed_in? && !current_user.has_location? %>
      <div style="background: #fff3e0; padding: 10px; border-radius: 8px; margin-bottom: 15px;">
        📍 <%= link_to "Set your location", edit_user_path(current_user) %>
        to see how far this item is from you!
      </div>
    <% end %>

    <%# THE MAP %>
    <div
      data-controller="map-display user-location"
      data-map-display-lat-value="<%= @item.latitude %>"
      data-map-display-lng-value="<%= @item.longitude %>"
      data-map-display-location-name-value="<%= @item.location_name %>"
      data-map-display-title-value="<%= @item.title %>"
      data-user-location-seller-lat-value="<%= @item.latitude %>"
      data-user-location-seller-lng-value="<%= @item.longitude %>"
      style="height: 300px; width: 100%; border-radius: 8px; overflow: hidden;">
    </div>

    <p style="margin-top: 8px; font-size: 14px;">
      📍 Coordinates: <%= @item.latitude %>, <%= @item.longitude %>
    </p>

    <%# USER LOCATION BUTTONS %>
    <div style="margin-top: 12px;">
      <button data-action="user-location#locateMe">
        📍 Locate Me
      </button>

      <button data-action="user-location#toggleDistance">
        📏 Compare Pickup Distance
      </button>

      <p data-user-location-target="output" style="margin-top: 8px;"></p>
    </div>

  </div>
<% else %>
  <p style="color: #999; margin: 20px 0;">📍 No location set for this item</p>
<% end %>

<div>
  <% if user_signed_in? && current_user == @item.user %>
    <%= button_to "Edit this item", edit_item_path(@item), method: :get %>
    <%= button_to "Destroy this item", @item, method: :delete,
                  data: { turbo_confirm: "Are you sure?" } %>
    <br>
  <% end %>

  <%= link_to "Back to items", items_path %>
</div>