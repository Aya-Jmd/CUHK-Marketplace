<p style="color: green"><%= notice %></p>

<div>
  Offer posted by <strong> <%= link_to (current_user == @item.user ? "you" : @item.user.email), user_path(@item.user) %></strong>, on <%= @item.created_at.strftime("%B %d, %Y at %I:%M %p") %>.
</div>

<% if @item.images.attached? %>
  <div class="item-gallery" data-controller="gallery" style="margin-top: 20px; margin-bottom: 20px;">
    
    <div class="main-image" style="margin-bottom: 10px; width: 100%; max-height: 500px; overflow: hidden; border-radius: 8px;">
      <%= image_tag @item.images.first, 
            data: { gallery_target: "mainImage" }, 
            style: "width: 100%; height: auto; object-fit: contain; max-height: 500px; background-color: #f8f9fa;" %>
    </div>

    <% if @item.images.count > 1 %>
      <div class="thumbnail-row" style="display: flex; gap: 10px; overflow-x: auto; padding-bottom: 10px;">
        <% @item.images.each do |image| %>
          
          <div style="flex: 0 0 auto; width: 100px; height: 100px; border-radius: 4px; overflow: hidden; border: 1px solid #ddd; cursor: pointer;"
               data-action="click->gallery#swap"
               data-full-url="<%= url_for(image) %>">
            
             <%= image_tag image.variant(resize_to_fill: [200, 200]), style: "width: 100%; height: 100%; object-fit: cover; pointer-events: none;" %>
          </div>
          
        <% end %>
      </div>
    <% end %>
    
  </div>
<% end %>
<br>

<%= render @item %>

<div style="margin-top: 30px; margin-bottom: 30px; padding: 20px; border: 1px solid #ddd; border-radius: 8px; background-color: #f9f9f9;">
  <% if user_signed_in? && current_user != @item.user %>
    
    <h3 style="margin-top: 0;">Make an Offer</h3>
    
    <%= form_with(model: [@item, Offer.new], local: true) do |form| %>
      <div style="display: flex; gap: 10px; align-items: center; margin-top: 10px;">
        <strong>HK$</strong>
        <%= form.number_field :price, step: 0.1, placeholder: "Enter amount...", required: true, style: "padding: 8px; border-radius: 4px; border: 1px solid #ccc;" %>
        <%= form.submit "Send Offer", style: "padding: 8px 16px; background-color: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer;" %>
      </div>
    <% end %>

  <% elsif user_signed_in? && current_user == @item.user %>
    <p style="margin: 0; color: #555;"><em>You own this item. Check your dashboard for incoming offers!</em></p>
  <% else %>
    <p style="margin: 0;"><%= link_to "Log in to make an offer", new_user_session_path %></p>
  <% end %>
</div>
<%# LOCATION MAP - Show item location if available %>
<% if @item.latitude.present? && @item.longitude.present? %>
  <div class="location-section" style="margin: 20px 0; padding: 15px; background: #f9f9f9; border-radius: 8px;">
    <h3>📍 Pickup Location</h3>
    
    <%# Show distance if user is signed in %>
    <% if user_signed_in? && current_user.has_location? && @distance %>
      <div style="background: #e8f5e9; padding: 10px; border-radius: 8px; margin-bottom: 15px;">
        <strong>🚶 Distance from your location:</strong>
        <span style="font-size: 18px; font-weight: bold; color: #2e7d32;">
          <%= @distance %> km
        </span>
        <span style="display: block; font-size: 14px; color: #666; margin-top: 5px;">
          <%= @distance_text %>
        </span>
      </div>
    <% elsif user_signed_in? && !current_user.has_location? %>
      <div style="background: #fff3e0; padding: 10px; border-radius: 8px; margin-bottom: 15px;">
        📍 <a href="<%= edit_user_path(current_user) %>">Set your location</a> to see how far this item is from you!
      </div>
    <% end %>

    <div data-controller="map-display"
         data-map-display-lat-value="<%= @item.latitude %>"
         data-map-display-lng-value="<%= @item.longitude %>"
         data-map-display-location-name-value="<%= @item.location_name %>"
         data-map-display-title-value="<%= @item.title %>"
         style="height: 300px; width: 100%; border-radius: 8px; overflow: hidden;">
    </div>

    <p class="location-hint" style="margin-top: 8px; font-size: 14px;">
      📍 Coordinates: <%= @item.latitude %>, <%= @item.longitude %>
    </p>

    <%# Nearby items %>
    <% if @nearby_items.present? %>
      <div style="margin-top: 20px;">
        <h4>📍 Other items nearby (within 1.5km)</h4>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px;">
          <% @nearby_items.each do |nearby| %>
            <div style="padding: 10px; border: 1px solid #eee; border-radius: 8px;">
              <%= link_to nearby.title, nearby, style: "text-decoration: none; color: #333; font-weight: bold;" %>
              <% if nearby.has_location? %>
                <span style="font-size: 12px; color: #666; display: block;">
                  📍 <%= (LocationService.calculate_distance(@item.latitude, @item.longitude, nearby.latitude, nearby.longitude)).round(2) %> km away
                </span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p style="color: #999; margin: 20px 0;">📍 No location set for this item</p>
<% end %>

<div style="margin-top: 30px;">
  <% if user_signed_in? && (current_user == @item.user || current_user.admin? || (current_user.college_admin? && current_user.college_id == @item.college_id)) %>
    <div style="display: flex; gap: 10px; margin-bottom: 15px;">

      <%# Only let the actual owner edit the text/price %>
      <% if current_user == @item.user %>
        <%= button_to "Edit this item", edit_item_path(@item), method: :get, style: "padding: 8px 16px; border-radius: 4px; background-color: #e0e0e0; border: none; cursor: pointer;" %>
      <% end %>

      <%# Let Owners AND Admins delete the item %>
      <%= button_to "Destroy this item", @item, method: :delete, data: { turbo_confirm: "Are you sure?" }, style: "padding: 8px 16px; border-radius: 4px; background-color: #dc3545; color: white; border: none; cursor: pointer;" %>
    </div>
  <% end %>

  <%= link_to "Back to items", items_path, style: "text-decoration: none; color: #007bff;" %>
</div>