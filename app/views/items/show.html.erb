<p style="color: green"><%= notice %></p>

<div>
   Offer posted by <strong> <%= link_to  (current_user == @item.user ? "you" : @item.user.email), 
   user_path(@item.user) %></strong>, on <%= @item.created_at.strftime("%B %d, %Y at %I:%M %p") %>.
</div>

<br>

<%= render @item %>

<div>
  <% if user_signed_in? && current_user == @item.user %>
  <%= button_to "Edit this item", edit_item_path(@item), method: :get %>
  <%= button_to "Destroy this item", @item, method: :delete, data: { turbo_confirm: "Are you sure?" } %>
  <br>
  <% end %>

  <%= link_to "Back to items", items_path %>

</div>


