<article class="market-card market-card--skeleton" role="presentation" aria-hidden="true">
  <div class="market-card__media market-card__media--skeleton">
    <span class="market-card__skeleton-block market-card__skeleton-block--shine"></span>
  </div>

  <div class="market-card__body">
    <div class="market-card__badges">
      <span class="market-card__skeleton-pill"></span>
      <span class="market-card__skeleton-pill market-card__skeleton-pill--wide"></span>
    </div>

    <div class="market-card__skeleton-lines">
      <span class="market-card__skeleton-line market-card__skeleton-line--title"></span>
      <span class="market-card__skeleton-line market-card__skeleton-line--title-short"></span>
    </div>

    <div class="market-card__footer">
      <span class="market-card__skeleton-pill market-card__skeleton-pill--price"></span>
      <span class="market-card__skeleton-line market-card__skeleton-line--time"></span>
    </div>
  </div>
</article>
