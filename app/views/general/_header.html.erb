<% if user_signed_in? %>
  <% floating_nav = (controller.action_name == "index" && %w[items search].include?(controller.controller_name)) %>
  <% current_scope = marketplace_scope %>
  <div class="site-header <%= "site-header--floating" if floating_nav %>"<% if floating_nav %> data-controller="glass-header"<% end %>>
    <div class="site-header__left">
      <%= form_with url: search_path, method: :get, local: true, class: "site-header__search-form", role: "search" do %>
        <%= label_tag :q_header, "Search items", class: "site-header__search-label" %>
        <%= text_field_tag :q, params[:q].to_s, id: "q_header", placeholder: "Search items...", autocomplete: "off", class: "site-header__search-input" %>
        <%= hidden_field_tag :scope, current_scope, id: "header_scope" %>
        <% if params[:category_id].present? %>
          <%= hidden_field_tag :category_id, params[:category_id], id: "header_category_id" %>
        <% end %>
        <% if params[:sort].present? %>
          <%= hidden_field_tag :sort, params[:sort], id: "header_sort" %>
        <% end %>
        <% if params[:price_currency].present? %>
          <%= hidden_field_tag :price_currency, params[:price_currency], id: "header_price_currency" %>
        <% end %>
        <% if params[:min_price].present? %>
          <%= hidden_field_tag :min_price, params[:min_price], id: "header_min_price" %>
        <% end %>
        <% if params[:max_price].present? %>
          <%= hidden_field_tag :max_price, params[:max_price], id: "header_max_price" %>
        <% end %>

        <%= button_tag type: "submit",
          class: ["site-header__search-submit", ("site-header__search-submit--hidden" if floating_nav)].compact.join(" "),
          title: "Search",
          aria: { label: "Search" } do %>
          <span aria-hidden="true">&#128269;</span>
          <span class="site-header__search-label">Search</span>
        <% end %>
      <% end %>
    </div>

    <div class="site-header__center">
      <%= link_to items_path(scope: current_scope), class: "site-header__logo", aria: { label: "Go to main menu" } do %>
        <span>CUHK MRKT</span>
      <% end %>
    </div>

    <div class="site-header__right">
      <% if floating_nav %>
        <nav class="site-header__scope-switch" aria-label="Marketplace scope">
          <%= link_to "CUHK",
              marketplace_scope_switch_path("all"),
              class: class_names("site-header__scope-option", { "is-active" => current_scope == "all" }) %>
          <%= link_to marketplace_college_label,
              marketplace_scope_switch_path("college"),
              class: class_names("site-header__scope-option", { "is-active" => current_scope == "college" }),
              title: marketplace_college_label %>
        </nav>
      <% end %>

      <% currency_codes = %w[HKD USD EUR] %>
      <%= form_with url: currency_path, method: :patch, class: "site-header__currency-form" do %>
        <details class="site-header__currency-menu">
          <summary class="site-header__currency">
            <span class="site-header__currency-value"><%= current_currency_code %></span>
            <span class="site-header__currency-chevron" aria-hidden="true"></span>
          </summary>

          <div class="site-header__currency-dropdown">
            <% currency_codes.each do |currency_code| %>
              <% option_classes = ["site-header__currency-option"] %>
              <% option_classes << "site-header__currency-option--active" if currency_code == current_currency_code %>
              <%= button_tag currency_code,
                type: "submit",
                name: "currency",
                value: currency_code,
                class: option_classes.join(" ") %>
            <% end %>
          </div>
        </details>
      <% end %>

      <details class="site-header__menu">
        <summary class="site-header__summary">
          Welcome, <%= current_user.email.split("@").first.capitalize %>
        </summary>

        <div class="site-header__dropdown">
          <%= link_to "My Profile", profile_path, class: "site-header__dropdown-link" %>
          <%= link_to "My Items", user_path(current_user), class: "site-header__dropdown-link site-header__dropdown-link--border" %>

          <hr class="site-header__dropdown-rule">

          <%= button_to "Sign Out", destroy_user_session_path, method: :delete,
              form: { class: "site-header__signout-form" },
              class: "site-header__signout" %>
        </div>
      </details>
    </div>
  </div>
<% end %>
