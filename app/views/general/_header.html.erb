<% if notice %>
  <div style="background-color: #d1e7dd; color: #0f5132; padding: 12px; text-align: center; border-radius: 0 0 8px 8px; margin-bottom: 20px; font-weight: bold; border: 1px solid #badbcc; max-width: 1200px; margin: 0 auto;">
    <%= notice %>
  </div>
<% end %>

<% if user_signed_in? %>
  <div style="max-width: 1200px; margin: 20px auto 30px auto; display: flex; justify-content: space-between; align-items: center; padding: 15px 20px; background-color: #ffffff; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border-left: 5px solid #3498db; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
    
    <div>
      <%= link_to "📊 View Price Analytics", category_prices_dashboard_path, style: "background-color: #f0f4f8; color: #2c3e50; padding: 10px 18px; border-radius: 8px; text-decoration: none; font-weight: bold; border: 1px solid #dcdde1; transition: all 0.2s;" %>
    </div>

    <div style="display: flex; align-items: center; gap: 15px;">
      
      <%= form_with url: currency_path, method: :patch, style: "margin: 0;" do |f| %>
        <div style="display: flex; align-items: center; background-color: #f8f9fa; border: 1px solid #dcdde1; border-radius: 8px; padding: 4px 10px; box-shadow: inset 0 1px 2px rgba(0,0,0,0.02);">
          <span style="font-size: 0.9em; margin-right: 6px;">💱</span>
          <%= select_tag :currency, options_for_select(['HKD', 'USD', 'EUR'], session[:currency_code] || 'HKD'), onchange: 'this.form.requestSubmit();', style: "border: none; background: transparent; font-weight: bold; color: #2c3e50; outline: none; cursor: pointer; font-size: 0.95em;" %>
        </div>
      <% end %>

      <details style="position: relative;">
        <summary style="list-style: none; cursor: pointer; color: #0984e3; font-weight: bold; padding: 8px 16px; border-radius: 8px; background-color: #e8f4f8; outline: none;">
          👋 Welcome, <%= current_user.email.split('@').first.capitalize %>! ▼
        </summary>
        
        <div style="position: absolute; right: 0; top: 120%; background-color: white; border: 1px solid #dcdde1; border-radius: 8px; box-shadow: 0 8px 16px rgba(0,0,0,0.1); padding: 8px; min-width: 160px; z-index: 9999;">
          
          <%= link_to user_path(current_user), style: "display: block; padding: 10px 12px; color: #2c3e50; text-decoration: none; font-weight: bold; border-radius: 6px;" do %>
            👤 My Profile
          <% end %>
          
          <hr style="border: 0; border-top: 1px solid #f1f2f6; margin: 5px 0;">
          
          <%= button_to destroy_user_session_path, method: :delete, form: { style: "margin: 0;" }, style: "width: 100%; text-align: left; background-color: transparent; color: #d63031; border: none; padding: 10px 12px; border-radius: 6px; cursor: pointer; font-weight: bold; font-size: 1em; display: flex; align-items: center; gap: 8px; font-family: inherit;" do %>
            <span style="font-size: 1.2em;">🚪</span> Sign Out
          <% end %>

        </div>
      </details>
      
    </div> </div> <% end %>