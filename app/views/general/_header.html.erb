<% if user_signed_in? %>
  <% current_scope = marketplace_scope %>
  <% if current_user.admin? %>
    <% scope_form_url = controller.controller_name == "search" && controller.action_name == "index" ? search_path : items_path %>
    <% college_options = [["CUHK Global", ""]] + College.order(:name).pluck(:name, :id) %>
  <% else %>
    <% next_scope = current_scope == "college" ? "all" : "college" %>
    <% current_scope_label = marketplace_scope_label(current_scope) %>
    <% next_scope_label = marketplace_scope_label(next_scope) %>
  <% end %>


  <!-- variable to store top 3 most recent non read notifications for hover display -->
  <% unread_notifications = current_user.notifications.where(read_at: nil) %>
  <% unread_notifications_count = unread_notifications.count %>
  <% recent_notifications = unread_notifications.includes(:actor, :notifiable).order(created_at: :desc).limit(3) %>


  <div class="site-header site-header--minimal" data-controller="glass-header">
    <%= link_to items_path(marketplace_base_params(current_scope)), class: "site-header__logo", aria: { label: "Go to homepage" } do %>
      <span>CUHK</span>
    <% end %>

    <% if current_user.admin? %>
      <div class="site-header__scope-switch">
          <%= form_with url: scope_form_url, method: :get, local: true, class: "site-header__scope-form" do %>
            <%= hidden_field_tag :q, params[:q] if params[:q].present? %>
            <%= hidden_field_tag :category_id, params[:category_id] if params[:category_id].present? %>
            <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
            <%= hidden_field_tag :price_currency, params[:price_currency] if params[:price_currency].present? %>
            <%= hidden_field_tag :min_price, params[:min_price] if params[:min_price].present? %>
            <%= hidden_field_tag :max_price, params[:max_price] if params[:max_price].present? %>

            <%= select_tag :college_scope_id,
                options_for_select(college_options, params[:college_scope_id]),
                class: "site-header__scope-select",
                onchange: "this.form.requestSubmit()" %>
          <% end %>
        </div>
      <% else %>
        <nav class="site-header__scope-switch" aria-label="Marketplace scope">
          <%= link_to marketplace_scope_switch_path(next_scope),
              class: class_names("site-header__scope-toggle", { "is-college" => current_scope == "college" }),
              aria: { label: "Switch marketplace scope to #{next_scope_label}" },
              title: "Switch to #{next_scope_label}" do %>
            <span class="site-header__scope-toggle-text"><%= current_scope_label %></span>
            <span class="site-header__scope-toggle-track" aria-hidden="true">
              <span class="site-header__scope-toggle-thumb"></span>
            </span>
          <% end %>
        </nav>
      <% end %>



    <% currency_codes = %w[HKD USD EUR] %>
    <%= form_with url: currency_path, method: :patch, local: true, class: "site-header__currency-form" do %>
      <%= select_tag :currency,
          options_for_select(currency_codes, current_currency_code),
          class: "site-header__currency-select",
          onchange: "this.form.requestSubmit()" %>
    <% end %>

    <%= form_with url: search_path, method: :get, local: true, class: "site-header__search-form", role: "search" do %>
      <%= label_tag :q_header, "Search items", class: "site-header__search-label" %>
      <%= text_field_tag :q, params[:q].to_s, id: "q_header", placeholder: "Search items...", autocomplete: "off", class: "site-header__search-input" %>
      <% unless current_user.admin? %>
        <%= hidden_field_tag :scope, current_scope, id: "header_scope" %>
      <% end %>
      <% if current_user.admin? && params[:college_scope_id].present? %>
        <%= hidden_field_tag :college_scope_id, params[:college_scope_id], id: "header_college_scope_id" %>
      <% end %>
      <% if params[:category_id].present? %>
        <%= hidden_field_tag :category_id, params[:category_id], id: "header_category_id" %>
      <% end %>
      <% if params[:sort].present? %>
        <%= hidden_field_tag :sort, params[:sort], id: "header_sort" %>
      <% end %>
      <% if params[:price_currency].present? %>
        <%= hidden_field_tag :price_currency, params[:price_currency], id: "header_price_currency" %>
      <% end %>
      <% if params[:min_price].present? %>
        <%= hidden_field_tag :min_price, params[:min_price], id: "header_min_price" %>
      <% end %>
      <% if params[:max_price].present? %>
        <%= hidden_field_tag :max_price, params[:max_price], id: "header_max_price" %>
      <% end %>

      <%= button_tag type: "submit", class: "site-header__search-submit", aria: { label: "Search" } do %>
        <%= image_tag "search-icon.png", alt: "", class: "site-header__icon-image" %>
      <% end %>

      <!-- %= button_tag "Search", type: "submit", class: "site-header__search-submit", aria: { label: "Search" } % -->
    <% end %>


    <div class="site-header__notification-shell">
      <%= link_to notifications_path, class: "site-header__icon-link site-header__notification-link", aria: { label: "Notifications" } do %>
        <%= image_tag "nav_bell.svg", alt: "NOTIFICATIONS", class: "site-header__icon-image" %>
        <% if !unread_notifications_count.zero?  %>
          <span
            data-notification-target="badge"
            class="site-header__notification-badge"
            <%= "hidden" if unread_notifications_count.zero? %>>
            <%= unread_notifications_count > 99 ? "99+" : unread_notifications_count %>
          </span>
        <% end %>
      <% end %>

      <!-- FOR HOVER MECHANISM (DISPLAYS 3 MOST RECENTS NOTIFS WHEN HOVERING ON BELL) -->
      <div class="site-header__notification-dropdown">
        <% if recent_notifications.any? %> <!-- IF recent_notifications variable isn't empty -->
          <% recent_notifications.each do |notification| %>
            <!-- each notification goes to notifications page for now -->
            <%= link_to notifications_path, class: "site-header__notification-item site-header__notification-item--fresh" do %>
              <span class="site-header__notification-preview"><%= notification_message(notification) %></span>
              <span class="site-header__notification-time"><%= notification.created_at.strftime("%b %d, %H:%M") %></span>
            <% end %>
          <% end %>

          <%= link_to "See all notifications", notifications_path, class: "site-header__notification-footer" %>
        <% else %>
          <div class="site-header__notification-empty">No new notifications yet.</div>
        <% end %>
      </div>

    </div>


    <%= link_to "SELL", new_item_path, class: "site-header__sell-link" %>

    <%= link_to conversations_path, class: "site-header__icon-link", aria: { label: "Chat" } do %>
      <%= image_tag "nav_mail.svg", alt: "", class: "site-header__icon-image" %>
    <% end %>

    <div class="site-header__account-actions">
      <details class="site-header__menu">
        <summary class="site-header__icon-link site-header__summary" aria-label="Open account menu">
          <%= image_tag "nav_menu.png", alt: "", class: "site-header__icon-image" %>
        </summary>

        <div class="site-header__dropdown">
         
          <%= link_to "My Items", profile_path, class: "site-header__dropdown-link" %>

          <%= link_to "Market Overview", analytics_path, class: class_names("site-header__dropdown-link", { "site-header__dropdown-link--border" => current_user.admin? || current_user.college_admin? }) %>
          <% if current_user.admin? || current_user.college_admin? %>
            <hr class="site-header__dropdown-rule">
            <%= link_to "Admin Panel", admin_root_path, class: "site-header__dropdown-link" %>
          <% end %>
        </div>
      </details>

      <details class="site-header__menu">
        <summary class="site-header__icon-link site-header__summary" aria-label="Open profile menu">
          <%= image_tag "nav_user.svg", alt: "", class: "site-header__icon-image" %>
        </summary>

        <div class="site-header__dropdown">
          <%= link_to "My Profile", edit_profile_path, class: "site-header__dropdown-link" %>
          <hr class="site-header__dropdown-rule">
          <%= button_to "Sign Out", destroy_user_session_path, method: :delete,
              form: { class: "site-header__signout-form" },
              class: "site-header__signout" %>
        </div>
      </details>
    </div>
  </div>
<% end %>
